# AutoBrand AI — environment template
# Copy to .env for local development: cp .env.example .env
# In production, set these as environment variables on your hosting
# platform's dashboard (Render/Railway/Heroku/Fly.io) — never upload
# a real .env file, and never commit one.

# App
APP_NAME=AutoBrand AI
APP_URL=http://localhost:3200
# Instagram cannot fetch localhost media. For local Instagram publishing, either
# configure Cloudinary below or expose this server through a public HTTPS tunnel
# and put that HTTPS origin here. Facebook Pages can upload local files directly.
PUBLIC_APP_URL=http://localhost:3200
PORT=3200
NODE_ENV=development
# Publishing runs automatically in the web process. Use this only as an emergency stop.
PAUSE_PUBLISHING=false
APP_TIME_ZONE=Africa/Kampala
DUE_POST_CONCURRENCY=3
DUE_POST_POLL_MS=10000
POST_PUBLISH_CONCURRENCY=3
SOCIAL_PROVIDER_TIMEOUT_MS=300000
PUBLISHING_STALE_MS=900000
GENERATION_ACTION_RECOVERY_MS=30000
REDIS_PING_TIMEOUT_MS=1500
MONGO_WORKER_BACKOFF_MIN_MS=5000
MONGO_WORKER_BACKOFF_MAX_MS=120000
MONGO_WORKER_LOG_INTERVAL_MS=60000
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=15000
MONGO_SOCKET_TIMEOUT_MS=45000
# Set 4 only when your network has problematic IPv6 DNS/routing.
MONGO_IP_FAMILY=

# Database & cache
MONGO_URI=mongodb://127.0.0.1:27017/ai-autobrand
# Generated images/videos are stored in MongoDB GridFS by default so database
# records never point to deleted local files. Set local only for throwaway dev data.
GENERATED_MEDIA_STORAGE=gridfs
GENERATED_MEDIA_GRIDFS_BUCKET=autobrand_generated_media
# Redis is optional. Leave disabled for the normal one-service MongoDB fallback.
# A non-empty REDIS_URL enables Redis automatically. Host/port mode additionally
# requires REDIS_ENABLED=true so localhost connection errors cannot loop forever.
REDIS_ENABLED=false
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
QUEUE_PREFIX=autobrand

# Secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_value
JWT_REFRESH_SECRET=replace_with_a_long_random_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace_with_a_long_random_value
CSRF_SECRET=replace_with_a_long_random_value
WEBHOOK_SECRET=replace_with_a_long_random_value
TOKEN_ENCRYPTION_KEY=replace_with_a_distinct_long_random_value
# During an intentional key rotation, keep the old key here until all connected
# accounts have been reconnected/re-encrypted. Multiple old keys may be comma-separated.
TOKEN_ENCRYPTION_KEY_PREVIOUS=
# Development only: when TOKEN_ENCRYPTION_KEY is blank, the app persists one here
# so nodemon restarts do not invalidate every connected social account.
TOKEN_ENCRYPTION_KEY_FILE=.autobrand-token-key

# Email delivery
# optional: app starts without SMTP; verification is disabled unless explicitly required
# required: startup fails unless complete SMTP credentials are present
# disabled: never send email even when SMTP variables exist
EMAIL_DELIVERY_MODE=optional
EMAIL_VERIFICATION_REQUIRED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Development only. Keep false in production.
ALLOW_DEVELOPMENT_EMAIL_LINKS=false

# Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3200/auth/google/callback
GOOGLE_OAUTH_TIMEOUT_MS=30000
GOOGLE_OAUTH_CONNECT_TIMEOUT_MS=30000
# Use this only if Node cannot reach Google because of a proxy. Requires https-proxy-agent. Example: http://user:pass@proxy-host:8080
GOOGLE_OAUTH_PROXY=
# Useful on Windows/networks where IPv6 Google connections time out. Allowed: ipv4first, ipv6first, verbatim
GOOGLE_OAUTH_DNS_ORDER=ipv4first
GOOGLE_OAUTH_IP_FAMILY=

# YouTube Shorts upload (falls back to GOOGLE_CLIENT_ID/SECRET if blank)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/youtube/callback
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.upload https://www.googleapis.com/auth/youtube.readonly
YOUTUBE_DEFAULT_PRIVACY=public

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/linkedin/callback
LINKEDIN_SCOPES=openid profile email w_member_social
LINKEDIN_VERSION=202607

# Cloudinary (media hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/facebook/callback
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_LOGIN_CONFIG_ID=
FACEBOOK_ALLOW_CLASSIC_OAUTH=false
FACEBOOK_APP_DOMAINS=your-domain.example
# Scopes below cover Facebook Pages + Instagram discovery in one grant
# (see Instagram note next) — this is the only scopes var the app reads.
FACEBOOK_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement,instagram_basic,instagram_content_publish,business_management

# Instagram
# No separate credentials: Instagram publishing runs through the Facebook app
# above (Graph API) using a token from the Facebook connect flow. Nothing to
# fill in here — just make sure instagram_basic/instagram_content_publish are
# in FACEBOOK_SCOPES and the connected Facebook Page has a linked IG Business account.

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish

# Google Business Profile locations (falls back to GOOGLE_CLIENT_ID/SECRET if blank)
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/google-business/callback
GOOGLE_BUSINESS_SCOPES=https://www.googleapis.com/auth/business.manage

# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/pinterest/callback
PINTEREST_SCOPES=boards:read,pins:read,pins:write,user_accounts:read
PINTEREST_CONTINUOUS_REFRESH=true

# X / Twitter (OAuth 2.0 PKCE)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/x/callback
X_SCOPES=tweet.read tweet.write users.read offline.access media.write
# Optional aliases if your deployment already uses the Twitter naming convention:
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/x/callback
TWITTER_SCOPES=tweet.read tweet.write users.read offline.access media.write

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_CALLBACK_URL=http://localhost:3200/dashboard/actions/social/threads/callback
THREADS_SCOPES=threads_basic,threads_content_publish
THREADS_GRAPH_VERSION=v1.0

# Superadmin seeder — change the password before running npm run seed in any shared environment
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!

# Billing — Pesapal is the only wired-in provider
BILLING_PROVIDER=pesapal
CHECKOUT_DEFAULT_PROVIDER=pesapal
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=
PESAPAL_IPN_URL=
PESAPAL_CALLBACK_URL=
PESAPAL_CANCELLATION_URL=
PESAPAL_REDIRECT_MODE=TOP_WINDOW
PESAPAL_AUTO_REGISTER_IPN=false
PESAPAL_BRANCH=
PESAPAL_TIMEOUT_MS=30000

# AI routing
AI_TEXT_PROVIDER=openai
AI_IMAGE_PROVIDER=openai
AI_VIDEO_PROVIDER=openai
ALLOW_LOCAL_VIDEO_FALLBACK=true
# web = one-service deployment; external = npm run worker:ai is running elsewhere; off = maintenance only
AI_GENERATION_WORKER_MODE=web
AI_GENERATION_POLL_MS=2500
AI_GENERATION_CONCURRENCY=2
# Separate lanes keep long MP4 rendering from blocking text/image/carousel jobs.
AI_CONTENT_GENERATION_CONCURRENCY=2
AI_VIDEO_GENERATION_CONCURRENCY=1
# Generate carousel slides in parallel within one job.
AI_IMAGE_GENERATION_CONCURRENCY=3
FFMPEG_PATH=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_QUALITY=medium
OPENAI_VIDEO_MODEL=sora-2
ALLOW_LOCAL_IMAGE_FALLBACK=false

# Additional AI providers (optional) — the adapters exist and are tested, but are
# inert until a key is set here. Leave blank unless you're adding a provider.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview
DEEPSEEK_API_KEY=
DEEPSEEK_TEXT_MODEL=deepseek-chat
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-latest
MISTRAL_API_KEY=
MISTRAL_TEXT_MODEL=mistral-large-latest
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_VIDEO_MODEL=default-video
STABILITY_API_KEY=
STABILITY_IMAGE_MODEL=stable-image-core
FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_VIDEO_MODEL=fal-ai/video
