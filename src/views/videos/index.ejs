<section class="workspace-hero compact-hero">
  <div>
    <p class="eyebrow">AI studio</p>
    <h2>Generate customer-winning videos, image-to-video ads, and owner clips</h2>
    <p>Create polished short-form videos with better hooks, realistic motion prompts, platform framing, and clean previews. Use OpenAI or Replicate renderers when configured, or save a strong provider-ready scene plan.</p>
  </div>
  <div class="hero-action-card">
    <strong>Missing provider keys?</strong>
    <p>Use Gemini for text and Replicate for image/video rendering now. You can change providers later from .env without rewriting the app.</p>
    <div class="video-quality-strip"><span>Strong hook</span><span>Realistic motion</span><span>Subtitle safe</span></div><a class="button ghost" href="/media">Upload media</a>
  </div>
</section>

<% if (error) { %><section class="panel"><p class="form-error"><%= error %></p></section><% } %>

<section class="ai-studio-grid">
  <article class="panel studio-card">
    <p class="eyebrow">brand to video</p>
    <h2>Automatic AI video</h2>
    <p class="muted">Best for quick promo videos from your Brand Brain, offer, and optional media.</p>
    <% if (!brands.length) { %><p class="form-error">Create a brand first.</p><% } else { %>
      <form action="/videos/auto-generate" method="post" class="form-grid compact-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %></select></label>
        <label>Platform<select name="platform"><option>Facebook</option><option>Instagram Reels</option><option>TikTok</option><option>YouTube Shorts</option></select></label>
        <label>Aspect ratio<select name="aspectRatio"><option>9:16</option><option>1:1</option><option>16:9</option></select></label>
        <label>Duration <input name="durationSeconds" type="number" min="6" max="60" value="20"></label>
        <label>Goal <input name="goal" placeholder="Sell weekend offer"></label>
        <label>Style <input name="style" placeholder="premium cinematic, realistic, bright, smooth motion"></label>
        <label>Provider <select name="provider"><option value="">Default provider</option><option value="replicate">Replicate video API</option><option value="planning">Plan only</option></select></label>
        <label>Video model <input name="videoModel" placeholder="owner/model, optional"></label>
        <label class="checkbox-row span-2"><input name="renderVideo" type="checkbox"> Render video now if video API key is configured.</label>
        <label class="span-2">Offer <input name="offer" placeholder="Main offer"></label>
        <label class="span-2">Use uploaded media<select name="sourceMedia" multiple><% media.forEach((item) => { %><option value="<%= item._id %>"><%= item.brand.name %> / <%= item.fileName %> (<%= item.fileType %>)</option><% }) %></select></label>
        <label class="span-2">Prompt <textarea name="prompt" rows="3" placeholder="Optional extra direction"></textarea></label>
        <button class="button span-2" type="submit">Create premium video</button>
      </form>
    <% } %>
  </article>

  <article class="panel studio-card">
    <p class="eyebrow">image to video</p>
    <h2>Use your images to create videos</h2>
    <p class="muted">Select uploaded product/owner images and build a motion-safe scene plan for a video provider.</p>
    <form action="/videos/image-to-video" method="post" class="form-grid compact-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %></select></label>
      <label>Provider <select name="provider"><option value="replicate">Replicate video API</option><option value="planning">Plan only</option></select></label>
      <label>Platform <input name="platform" value="Facebook"></label>
      <label>Aspect ratio<select name="aspectRatio"><option>9:16</option><option>1:1</option><option>16:9</option></select></label>
      <label>Duration <input name="durationSeconds" type="number" min="6" max="60" value="20"></label>
      <label>Style <input name="style" placeholder="cinematic product motion, realistic lighting, subtitle-safe"></label>
      <label class="span-2">Select images/videos<select name="sourceMedia" multiple required><% media.forEach((item) => { %><option value="<%= item._id %>"><%= item.brand.name %> / <%= item.fileName %> (<%= item.fileType %>)</option><% }) %></select></label>
      <label class="span-2">Prompt <textarea name="prompt" rows="3" placeholder="Describe the video movement and message"></textarea></label>
      <button class="button span-2" type="submit">Create premium image-to-video</button>
    </form>
  </article>

  <article class="panel studio-card">
    <p class="eyebrow">owner/avatar video</p>
    <h2>Owner/self video plan</h2>
    <p class="muted">For videos that use your own images or likeness. Consent is required before using personal media.</p>
    <form action="/videos/avatar-video" method="post" class="form-grid compact-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %></select></label>
      <label>Provider <select name="provider"><option value="replicate">Replicate video API</option><option value="planning">Plan only</option></select></label>
      <label>Platform <input name="platform" value="Facebook"></label>
      <label>Aspect ratio<select name="aspectRatio"><option>9:16</option><option>1:1</option><option>16:9</option></select></label>
      <label>Duration <input name="durationSeconds" type="number" min="10" max="90" value="20"></label>
      <label>Video model <input name="videoModel" placeholder="owner/model, optional"></label>
      <label class="checkbox-row span-2"><input name="renderVideo" type="checkbox"> Render video now if video API key is configured.</label>
      <label>Offer <input name="offer" placeholder="What should the owner promote?"></label>
      <label class="span-2">Approved owner media<select name="sourceMedia" multiple required><% media.forEach((item) => { %><option value="<%= item._id %>"><%= item.brand.name %> / <%= item.fileName %> (<%= item.consentStatus %>)</option><% }) %></select></label>
      <label class="span-2">Script <textarea name="script" rows="4" placeholder="What should the owner/avatar say?"></textarea></label>
      <label class="checkbox-row span-2"><input name="ownerConsent" type="checkbox" required> I confirm I own or have consent to use this likeness/media.</label>
      <button class="button span-2" type="submit">Create owner video</button>
    </form>
  </article>

  <article class="panel studio-card">
    <p class="eyebrow">clean text to video</p>
    <h2>Text-only video prompt</h2>
    <p class="muted">Build a clean provider prompt from text, brand rules, and optional media.</p>
    <form action="/videos/clean-generate" method="post" class="form-grid compact-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %></select></label>
      <label>Provider <select name="provider"><option value="replicate">Replicate video API</option><option value="planning">Plan only</option></select></label>
      <label>Platform <input name="platform" value="Facebook"></label>
      <label>Aspect ratio<select name="aspectRatio"><option>9:16</option><option>1:1</option><option>16:9</option></select></label>
      <label>Duration <input name="durationSeconds" type="number" min="10" max="120" value="20"></label>
      <label>Video model <input name="videoModel" placeholder="owner/model, optional"></label>
      <label class="checkbox-row span-2"><input name="renderVideo" type="checkbox"> Render video now if video API key is configured.</label>
      <label>Offer <input name="offer" placeholder="Main offer"></label>
      <label class="span-2">Prompt <textarea name="prompt" rows="4" required placeholder="Fully automatic video prompt from text and Brand Brain"></textarea></label>
      <label class="span-2">Style <input name="style" placeholder="premium, clean, realistic, subtitle-safe"></label>
      <button class="button span-2" type="submit">Queue premium video</button>
    </form>
  </article>
</section>

<section class="panel">
  <div class="section-heading-row">
    <div>
      <p class="eyebrow">handoff queue</p>
      <h2>Recent creative jobs</h2>
    </div>
    <a class="button ghost" href="/posts/handoff">Auto schedule posts</a>
  </div>
  <% if (!jobs.length) { %><p class="muted">No video jobs yet.</p><% } %>
  <% jobs.forEach((job) => { %>
    <article class="job-card video-job-card">
      <div>
        <% if (job.outputUrl) { %>
          <video class="video-job-preview" src="<%= job.outputUrl %>" controls preload="metadata" playsinline></video>
        <% } else { %>
          <div class="video-preview-frame"><div><strong><%= job.brand.name %></strong><p><%= job.status %> / <%= job.aspectRatio %></p></div></div>
        <% } %>
        <p class="eyebrow"><%= job.mode %> / <%= job.status %></p>
        <h3><%= job.brand.name %></h3>
        <p><%= job.prompt %></p>
        <p class="muted"><%= job.aspectRatio %> / <%= job.durationSeconds %>s / <%= job.costCredits %> credits / <%= job.provider %></p>
        <% if (job.outputUrl) { %><p><a href="<%= job.outputUrl %>">Output URL</a></p><% } %>
        <% if (job.scenePlan && job.scenePlan.length) { %>
          <ol class="clean-list scene-list">
            <% job.scenePlan.forEach((scene, index) => { %>
              <li>
                <strong><%= scene.title %>:</strong> <%= scene.narration %>
                <details><summary>Provider prompt</summary><p><%= scene.visualPrompt %></p></details>
                <form action="/videos/<%= job._id %>/regenerate-scene" method="post" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="sceneIndex" value="<%= index %>">
                  <input name="note" placeholder="Regeneration note">
                  <button class="button ghost" type="submit">Regenerate scene</button>
                </form>
              </li>
            <% }) %>
          </ol>
        <% } %>
      </div>
      <div class="stack-actions">
        <form action="/videos/<%= job._id %>/status" method="post" class="form-stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="status"><% ['queued', 'planning', 'generating', 'ready', 'failed', 'cancelled'].forEach((status) => { %><option value="<%= status %>" <%= job.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select>
          <input name="outputUrl" placeholder="Output URL" value="<%= job.outputUrl || '' %>">
          <button class="button ghost" type="submit">Update</button>
        </form>
        <form action="/videos/<%= job._id %>/create-post" method="post" class="form-stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="platform"><option value="facebook">Facebook</option><option value="instagram">Instagram</option><option value="tiktok">TikTok</option><option value="youtube">YouTube Shorts</option><option value="whatsapp">WhatsApp</option></select>
          <button class="button ghost" type="submit">Create draft</button>
        </form>
        <form action="/videos/<%= job._id %>/cancel" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button ghost" type="submit">Cancel</button></form>
      </div>
    </article>
  <% }) %>
</section>
