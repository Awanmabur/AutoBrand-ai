<section class="panel" style="max-width:820px;margin:3rem auto;">
  <div class="section-kicker">Client approval</div>
  <h1>Review content</h1>
  <p class="muted">Expires: <%= link.expiresAt.toISOString() %></p>
  <% if (link.post) { %>
    <article class="item-card">
      <h2><%= link.post.title || link.post.platform %></h2>
      <p><%= link.post.caption %></p>
      <% if (link.post.hashtags && link.post.hashtags.length) { %><p><%= link.post.hashtags.join(' ') %></p><% } %>
    </article>
  <% } else if (link.campaign) { %>
    <article class="item-card">
      <h2><%= link.campaign.name %></h2>
      <p><%= link.campaign.description || link.campaign.goal %></p>
      <% if (link.campaign.platforms && link.campaign.platforms.length) { %><p><%= link.campaign.platforms.join(', ') %></p><% } %>
    </article>
  <% } %>
  <form action="/review/<%= token %>" method="post" class="auth-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <textarea name="decisionNote" rows="4" placeholder="Optional feedback"></textarea>
    <div class="row-actions">
      <button class="button" name="decision" value="approved" type="submit">Approve</button>
      <button class="button ghost" name="decision" value="changes_requested" type="submit">Request changes</button>
      <button class="button ghost" name="decision" value="rejected" type="submit">Reject</button>
    </div>
  </form>
</section>
