<section class="panel">
  <h2>Request approval</h2>
  <% if (!draftPosts.length) { %>
    <p class="form-error">Create a draft before requesting approval.</p>
  <% } else { %>
    <form action="/dashboard/actions/approvals/request" method="post" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Post
        <select name="post" required>
          <% draftPosts.forEach((post) => { %><option value="<%= post._id %>"><%= post.brand.name %> - <%= post.title || post.caption.slice(0, 40) %></option><% }) %>
        </select>
      </label>
      <label>Reviewer email <input name="reviewerEmail" type="email"></label>
      <label class="span-2">Note <textarea name="note" rows="3"></textarea></label>
      <button class="button" type="submit">Send for approval</button>
    </form>
  <% } %>
</section>

<section class="post-list">
  <% if (!approvals.length) { %><article class="empty-state"><h2>No approvals</h2><p>Send drafts to clients or reviewers.</p></article><% } %>
  <% approvals.forEach((approval) => { %>
    <article class="post-row approval-row">
      <div>
        <p class="eyebrow"><%= approval.post.brand.name %> - <%= approval.status %></p>
        <h2><%= approval.post.title || 'Approval request' %></h2>
        <p><%= approval.note || approval.post.caption %></p>
        <% const approvalComments = commentsByApproval[approval._id.toString()] || []; %>
        <% if (approvalComments.length) { %>
          <div class="comment-list">
            <% approvalComments.forEach((comment) => { %>
              <p><strong><%= comment.authorName || 'Reviewer' %>:</strong> <%= comment.body %></p>
            <% }) %>
          </div>
        <% } %>
        <form action="/dashboard/actions/approvals/<%= approval._id %>/comment" method="post" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input name="comment" placeholder="Add comment or change note" required>
          <button class="button ghost" type="submit">Comment</button>
        </form>
      </div>
      <div class="stack-actions">
        <form action="/dashboard/actions/approvals/<%= approval._id %>/resolve" method="post" class="row-actions">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" name="status" value="approved" type="submit">Approve</button>
          <button class="button ghost" name="status" value="changes_requested" type="submit">Request changes</button>
          <button class="button ghost" name="status" value="rejected" type="submit">Reject</button>
        </form>
      </div>
    </article>
  <% }) %>
</section>
