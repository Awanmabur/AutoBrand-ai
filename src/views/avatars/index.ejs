<section class="panel">
  <h2>Create avatar profile</h2>
  <p>Avatar/clone video requires explicit consent. Provider training connects later through the avatar provider adapter.</p>
  <% if (!brands.length) { %>
    <p class="form-error">Create a Brand Brain first.</p>
  <% } else { %>
    <form action="/avatars" method="post" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand
        <select name="brand" required>
          <% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %>
        </select>
      </label>
      <label>Name <input name="name" placeholder="Business owner avatar" required></label>
      <label>Source media
        <select name="sourceMedia">
          <option value="">No media selected</option>
          <% media.forEach((item) => { %><option value="<%= item._id %>"><%= item.fileName %> / consent: <%= item.consentStatus %></option><% }) %>
        </select>
      </label>
      <label>Allowed use <input name="allowedUse" value="brand_content"></label>
      <label class="checkbox-row span-2"><input name="ownershipConfirmed" type="checkbox" required> I confirm I own this media or have permission to create an AI avatar from it.</label>
      <button class="button" type="submit">Create avatar profile</button>
    </form>
  <% } %>
</section>

<section class="post-list">
  <% if (!avatars.length) { %><article class="empty-state"><h2>No avatars</h2><p>Create an avatar profile for premium clone video workflows.</p></article><% } %>
  <% avatars.forEach((avatar) => { %>
    <article class="post-row">
      <div>
        <p class="eyebrow"><%= avatar.brand.name %></p>
        <h2><%= avatar.name %></h2>
        <p><%= avatar.allowedUse %></p>
        <p class="muted">Consent version: <%= avatar.consentVersion %></p>
        <form action="/avatars/<%= avatar._id %>/generate-video" method="post" class="form-stack section-subtitle">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label>Script <textarea name="script" rows="3" required placeholder="Write the presenter script"></textarea></label>
          <div class="inline-form">
            <select name="aspectRatio">
              <option>9:16</option>
              <option>1:1</option>
              <option>16:9</option>
            </select>
            <input name="durationSeconds" type="number" min="10" max="120" value="30">
            <button class="button ghost" type="submit">Create avatar video job</button>
          </div>
        </form>
      </div>
      <div class="stack-actions">
        <span class="status-pill"><%= avatar.status %></span>
        <form action="/avatars/<%= avatar._id %>/revoke" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Revoke/delete</button>
        </form>
      </div>
    </article>
  <% }) %>
</section>
