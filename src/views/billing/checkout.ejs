<section class="panel">
  <div class="section-kicker"><%= payment ? 'Payment' : 'Checkout' %></div>
  <h2><%= plan ? plan.name : 'Subscription payment' %></h2>
  <% if (plan) { %>
    <p><%= plan.description %></p>
    <div class="price"><%= plan.priceLabel %><% if (!plan.isTrial) { %><span>/<%= plan.intervalLabel %></span><% } %></div>
    <ul class="feature-list">
      <% plan.featureList.forEach((feature) => { %><li><%= feature %></li><% }) %>
    </ul>
  <% } %>

  <% if (payment) { %>
    <div class="item-grid">
      <article class="mini-record"><strong>Reference</strong><span><%= payment.reference %></span></article>
      <article class="mini-record"><strong>Amount</strong><span><%= payment.currency %> <%= payment.amount %></span></article>
      <article class="mini-record"><strong>Status</strong><span><%= payment.status %></span></article>
      <article class="mini-record"><strong>Provider</strong><span><%= payment.provider %></span></article>
    </div>
    <% if (payment.status === 'paid') { %>
      <div class="row-actions"><a class="button" href="/billing">View active subscription</a></div>
    <% } else { %>
      <form action="/billing/payments/<%= payment._id %>/complete" method="post" class="form-grid">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="span-2">Payment note
          <input name="paymentNote" placeholder="Bank transfer, mobile money, card reference, or internal approval">
        </label>
        <button class="button" type="submit">Confirm payment and activate</button>
        <a class="button ghost" href="/billing">Back to billing</a>
      </form>
    <% } %>
  <% } else { %>
    <form action="/billing/checkout/<%= plan.slug %>" method="post" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Payment provider
        <select name="provider">
          <option value="manual">Manual/offline payment</option>
          <option value="stripe">Stripe</option>
          <option value="paypal">PayPal</option>
          <option value="flutterwave">Flutterwave</option>
        </select>
      </label>
      <button class="button" type="submit">Create invoice</button>
    </form>
  <% } %>
</section>
