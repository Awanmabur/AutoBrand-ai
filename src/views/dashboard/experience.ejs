  <div class="drawer-backdrop" id="drawerBackdrop"></div>

  <aside class="sidebar" id="sidebar" aria-label="Dashboard sidebar">
    <div class="sidebar-top">
      <a class="brand" href="/dashboard/overview" data-page="overview">
        <span class="brand-logo">AB</span>
        <span><strong>AutoBrand AI</strong><small>Social SaaS</small></span>
      </a>
      <button class="icon-btn close-drawer" id="closeDrawer" type="button" aria-label="Close menu"><svg class="icon"><use href="#icon-x"></use></svg></button>
    </div>

    <div class="workspace-card">
      <span>Workspace</span>
      <strong><%= dashboardData.workspace.name %></strong>
      <small><%= dashboardData.workspace.subtitle %></small>
    </div>

    <div class="sidebar-scroll" id="sidebarScroll">
      <p class="nav-label">Overview</p>
      <nav class="side-nav">
        <a class="active" href="/dashboard/overview" data-page="overview"><span><svg class="icon"><use href="#icon-home"></use></svg>Dashboard</span><b>Home</b></a>
        <% if (canSeePage('quick-create')) { %><a href="/dashboard/quick-create" data-page="quick-create"><span><svg class="icon"><use href="#icon-plus"></use></svg>Full Composer</span><b>AI</b></a><% } %>
        <% if (canSeePage('brand-brain')) { %><a href="/dashboard/brand-brain" data-page="brand-brain"><span><svg class="icon"><use href="#icon-brain"></use></svg>Brand Brain</span><b><%= dashboardData.nav.brands %></b></a><% } %>
        <% if (canSeePage('content-library')) { %><a href="/dashboard/content-library" data-page="content-library"><span><svg class="icon"><use href="#icon-grid"></use></svg>Content Library</span><b><%= dashboardData.nav.content %></b></a><% } %>
      </nav>

      <p class="nav-label">Planning & Creative</p>
      <nav class="side-nav">
        <% if (canSeePage('campaigns')) { %><a href="/dashboard/campaigns" data-page="campaigns"><span><svg class="icon"><use href="#icon-chart"></use></svg>Campaigns & Growth</span><b><%= dashboardData.nav.campaigns %></b></a><% } %>
        <% if (canSeePage('media')) { %><a href="/dashboard/media" data-page="media"><span><svg class="icon"><use href="#icon-image"></use></svg>Media & Images</span><b><%= dashboardData.nav.images %></b></a><% } %>
        <% if (canSeePage('video-system')) { %><a href="/dashboard/video-system" data-page="video-system"><span><svg class="icon"><use href="#icon-play"></use></svg>Video Studio</span><b><%= dashboardData.nav.videos %></b></a><% } %>
        <% if (canSeePage('avatar-video')) { %><a href="/dashboard/avatar-video" data-page="avatar-video"><span><svg class="icon"><use href="#icon-avatar"></use></svg>Avatar Video</span><b><%= dashboardData.nav.avatars || 0 %></b></a><% } %>
      </nav>

      <p class="nav-label">Publishing</p>
      <nav class="side-nav">
        <% if (canSeePage('calendar')) { %><a href="/dashboard/calendar" data-page="calendar"><span><svg class="icon"><use href="#icon-calendar"></use></svg>Calendar & Schedule</span><b><%= dashboardData.nav.scheduled %></b></a><% } %>
        <% if (canSeePage('social')) { %><a href="/dashboard/social" data-page="social"><span><svg class="icon"><use href="#icon-send"></use></svg>Social Channels</span><b><%= dashboardData.nav.social %></b></a><% } %>
        <% if (canSeePage('approvals')) { %><a href="/dashboard/approvals" data-page="approvals"><span><svg class="icon"><use href="#icon-check"></use></svg>Approvals & Handoff</span><b><%= dashboardData.nav.approvals %></b></a><% } %>
        <% if (canSeePage('analytics')) { %><a href="/dashboard/analytics" data-page="analytics"><span><svg class="icon"><use href="#icon-chart"></use></svg>Analytics</span><b>Live</b></a><% } %>
        <a href="/dashboard/notifications" data-page="notifications"><span><svg class="icon"><use href="#icon-message"></use></svg>Notifications</span><b><%= dashboardData.nav.unread || '0' %></b></a>
      </nav>

      <p class="nav-label">Admin</p>
      <nav class="side-nav">
        <% if (canSeePage('team')) { %><a href="/dashboard/team" data-page="team"><span><svg class="icon"><use href="#icon-users"></use></svg>Team & Roles</span><b><%= dashboardData.nav.team || 0 %></b></a><% } %>
        <a href="/dashboard/billing" data-page="billing"><span><svg class="icon"><use href="#icon-card"></use></svg>Billing & Usage</span><b><%= dashboardData.nav.plan %></b></a>
        <% if (canSeeDashboardPlans) { %><a href="/dashboard/plans" data-page="plans"><span><svg class="icon"><use href="#icon-card"></use></svg>Plan Management</span><b>Plans</b></a><% } %>
        <a href="/dashboard/settings" data-page="settings"><span><svg class="icon"><use href="#icon-settings"></use></svg>Settings & Security</span><b><%= dashboardData.nav.unread || '.' %></b></a>
        <% if (visibleDashboardPages.includes('admin')) { %><a href="/dashboard/admin" data-page="admin"><span><svg class="icon"><use href="#icon-shield"></use></svg>Admin</span><b>Root</b></a><% } %>
        <div class="mobile-menu-actions" aria-label="Mobile account and theme controls">
          <button class="mobile-theme-toggle" id="themeToggleMenu" type="button" aria-label="Toggle theme">
            <svg class="icon mobile-theme-icon"><use href="#icon-moon"></use></svg>
            <strong>Dark mode</strong>
          </button>
          <div class="mobile-profile" aria-label="Current user">
            <span><%= dashboardData.user.initials %></span>
            <strong><%= dashboardData.user.firstName %></strong>
          </div>
        </div>
        <form class="side-nav-logout" action="/auth/logout" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="side-nav-button" type="submit"><span><svg class="icon"><use href="#icon-x"></use></svg>Logout</span><b>Exit</b></button>
        </form>
      </nav>

      <div class="upgrade-card">
        <strong>Upgrade to Studio</strong>
        <p>Unlock client approvals, clean AI video, avatar video, larger workspaces and premium exports.</p>
        <a class="btn btn-light" href="/dashboard/billing">View plan</a>
      </div>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <button class="icon-btn menu-btn" id="openDrawer" type="button" aria-label="Open menu"><svg class="icon"><use href="#icon-menu"></use></svg></button>
      <div class="top-title">
        <h1 id="pageTitle">Dashboard</h1>
      </div>
      <div class="top-actions">
        <input class="search" id="searchInput" type="search" placeholder="Search campaigns, brands, posts..." />
        <button class="icon-btn" id="themeToggle" type="button" aria-label="Toggle theme"><svg class="icon"><use href="#icon-moon"></use></svg></button>
        <button class="btn btn-primary" type="button" data-full-composer><svg class="icon"><use href="#icon-plus"></use></svg>Create</button>
        <div class="profile"><span><%= dashboardData.user.initials %></span><strong><%= dashboardData.user.firstName %></strong></div>
      </div>
    </header>

    <section class="page active" id="pageRoot" aria-live="polite"></section>
  </main>

  <div id="dashboardTemplates" hidden>
    <template id="dashboard-form-quick-create">
      <% if (!brands.length) { %>
        <article class="card real-form-card">
          <div class="card-head"><div><h3>Create Brand Brain first</h3><p>The AI needs a real brand record before it can generate useful posts.</p></div><span class="badge">Required</span></div>
          <%- include('partials/brand-quick-form', { csrfToken }) %>
        </article>
      <% } else { %>
        <article class="card real-form-card">
          <div class="card-head"><div><h3>Generate a real post</h3><p>Uses saved Brand Brain fields, connected accounts and media defaults.</p></div><span class="badge">Live post</span></div>
          <form action="/posts" method="post" class="real-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="creationMode" value="ai">
            <input type="hidden" name="generateImage" value="on">
            <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
            <label>Channel<select name="platform"><% platforms.forEach((platform) => { %><option value="<%= platform %>"><%= platform %></option><% }) %></select></label>
            <label>Media output<select name="mediaPreset"><option value="image-1">1 image</option><option value="carousel-3">3-image carousel</option><option value="video">Video</option><option value="text">Text only</option></select></label>
            <label>Content angle<select name="contentType"><option value="promo">Promo</option><option value="educational">Educational</option><option value="testimonial">Testimonial</option><option value="offer">Offer</option><option value="faq">FAQ</option></select></label>
            <label class="full">Goal<input name="goal" placeholder="Sell a service, announce an offer, collect WhatsApp inquiries"></label>
            <label class="full">Offer<input name="offer" placeholder="Use saved offer or override it here"></label>
            <div class="real-form-actions full">
              <button class="btn btn-ghost" name="action" value="save" type="submit">Save draft</button>
              <button class="btn btn-ghost" name="action" value="schedule" type="submit">Schedule</button>
              <button class="btn btn-primary" name="action" value="publish" type="submit">Publish now</button>
            </div>
          </form>
        </article>
      <% } %>
    </template>

    <template id="dashboard-form-brand-brain">
      <article class="card real-form-card" id="brand-form">
        <div class="card-head"><div><h3>Add Brand Brain data</h3><p>These fields map directly to the Brand model, so low-data workspaces can become useful fast.</p></div><a class="btn btn-ghost" href="/dashboard/brand-brain">All brands</a></div>
        <%- include('partials/brand-quick-form', { csrfToken }) %>
      </article>
    </template>

    <template id="dashboard-form-full-composer">
      <div class="classic-composer-modal dashboard-full-composer-shell">
        <%- include('partials/full-composer', {
          csrfToken,
          error: null,
          brands: composerBrands,
          form: composerForm,
          activeBrandId: composerBrands[0] ? composerBrands[0]._id : '',
          generated: null,
          socialAccounts: composerSocialAccounts,
          platforms,
          postTypes: composerPostTypes,
          contentTypes: composerContentTypes,
          contentGoals: composerContentGoals,
          media: composerMedia
        }) %>
      </div>
    </template>

    <template id="dashboard-form-content-library"></template>

    <template id="dashboard-form-campaigns">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Create campaign plan</h3><p>Writes a real Campaign document and AI plan.</p></div><a class="btn btn-ghost" href="/dashboard/campaigns">Campaigns</a></div>
        <% if (!brands.length) { %><p class="empty-state">Create a brand first before planning campaigns.</p><% } else { %>
          <form action="/campaigns" method="post" class="real-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
            <label>Name<input name="name" placeholder="Weekend voucher push" required></label>
            <label class="full">Goal<input name="goal" placeholder="Sell 100 daily vouchers"></label>
            <label>Platforms<input name="platforms" value="facebook, instagram, whatsapp"></label>
            <label>Duration days<input name="durationDays" type="number" min="1" max="30" value="7"></label>
            <label>Posting frequency<input name="postingFrequency" placeholder="2 posts per day"></label>
            <label>Start date<input name="startDate" type="date"></label>
            <label>End date<input name="endDate" type="date"></label>
            <label class="full">Description<textarea name="description" rows="3"></textarea></label>
            <button class="btn btn-primary full" type="submit">Create campaign plan</button>
          </form>
        <% } %>
      </article>
    </template>

    <template id="dashboard-form-calendar">
      <%- include('partials/post-schedule-form', { csrfToken, brands, platforms }) %>
    </template>

    <template id="dashboard-form-media">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Media library upload</h3><p>Upload media through the same working backend inside the clean dashboard.</p></div><a class="btn btn-primary" href="/dashboard/media">Media library</a></div>
        <% if (!brands.length) { %><p class="empty-state">Create a brand first before uploading media.</p><% } else { %>
          <form action="/media/upload" method="post" class="real-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input name="folder" type="hidden" value="external">
            <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
            <label>File type<select name="fileType"><option value="image">Image</option><option value="video">Video</option><option value="audio">Audio</option><option value="document">Document</option></select></label>
            <label>File name<input name="fileName" placeholder="Product photo"></label>
            <label>MIME type<input name="mimeType" placeholder="image/png"></label>
            <label class="full">Media URL<input name="fileUrl" type="url" placeholder="https://..." required></label>
            <label class="full">Tags<input name="tags" placeholder="logo, product, offer"></label>
            <label class="checkbox-line full"><input name="consentRequired" type="checkbox"> Contains a real person / likeness and needs consent</label>
            <button class="btn btn-primary full" type="submit">Save media asset</button>
          </form>
        <% } %>
      </article>
    </template>

    <template id="dashboard-form-video-system">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Generate video</h3><p>Creates a real AI video job using saved Brand Brain context.</p></div><a class="btn btn-ghost" href="/dashboard/video-system">Video studio</a></div>
        <% if (!brands.length) { %><p class="empty-state">Create a brand first before generating videos.</p><% } else { %>
          <form action="/videos/auto-generate" method="post" class="real-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
            <label>Platform<select name="platform"><option>Facebook</option><option>Instagram Reels</option><option>TikTok</option><option>YouTube Shorts</option></select></label>
            <label>Aspect ratio<select name="aspectRatio"><option>9:16</option><option>1:1</option><option>16:9</option></select></label>
            <label>Duration<input name="durationSeconds" type="number" min="6" max="60" value="20"></label>
            <label class="full">Goal<input name="goal" placeholder="Sell weekend offer"></label>
            <label class="full">Offer<input name="offer" placeholder="Main offer"></label>
            <label class="full">Style<input name="style" placeholder="premium realistic, bright, smooth motion"></label>
            <label class="full">Prompt<textarea name="prompt" rows="3" placeholder="Optional extra direction"></textarea></label>
            <label class="checkbox-line full"><input name="renderVideo" type="checkbox"> Render video now if provider API is configured</label>
            <button class="btn btn-primary full" type="submit">Create video job</button>
          </form>
        <% } %>
      </article>
    </template>

    <template id="dashboard-form-avatar-video">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Avatar video request</h3><p>Requires approved owner media and consent.</p></div><a class="btn btn-ghost" href="/dashboard/avatar-video">Avatar consent</a></div>
        <% if (!brands.length || !mediaAssets.length) { %><p class="empty-state">Add a brand and consent-ready owner media before creating avatar videos.</p><% } else { %>
          <form action="/videos/avatar-video" method="post" class="real-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
            <label>Aspect ratio<select name="aspectRatio"><option>9:16</option><option>1:1</option><option>16:9</option></select></label>
            <label>Duration<input name="durationSeconds" type="number" min="10" max="90" value="20"></label>
            <label>Provider<select name="provider"><option value="planning">Plan only</option><option value="replicate">Replicate video API</option></select></label>
            <label class="full">Approved owner media<select name="sourceMedia" multiple required><% mediaAssets.forEach((item) => { %><option value="<%= item.id %>"><%= item.brandName %> / <%= item.fileName %> (<%= item.consentStatus %>)</option><% }) %></select></label>
            <label class="full">Script<textarea name="script" rows="4" placeholder="What should the owner/avatar say?"></textarea></label>
            <label class="checkbox-line full"><input name="ownerConsent" type="checkbox" required> I confirm I own or have consent to use this likeness/media.</label>
            <button class="btn btn-primary full" type="submit">Create avatar video</button>
          </form>
        <% } %>
      </article>
    </template>

    <template id="dashboard-form-social">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Connected channels</h3><p>Use the real social API connection tools for OAuth and token health.</p></div><a class="btn btn-primary" href="/dashboard/social">Manage channels</a></div>
        <div class="channel-grid">
          <% ['facebook', 'instagram', 'linkedin', 'tiktok', 'youtube', 'whatsapp'].forEach((platform) => { %>
            <a class="channel-tile" href="/dashboard/social"><svg class="icon"><use href="#icon-<%= platform %>"></use></svg><span><%= platform %></span></a>
          <% }) %>
        </div>
      </article>
    </template>

    <template id="dashboard-form-approvals">
      <section class="handoff-workspace-shell">
        <article class="handoff-hero-card">
          <div>
            <span class="kicker">automatic posting</span>
            <h3>Generate the schedule from Brand Brain</h3>
            <p>Pick the brand and run it. AutoBrand uses saved frequency, slots, media mix, customer goal, platform language, products, offers, proof and rules.</p>
          </div>
          <div class="handoff-mini-card">
            <strong>Media first</strong>
            <span>Images and carousel slides are generated automatically. Video requests use video media or storyboard fallback when no renderer is configured.</span>
            <a class="btn btn-ghost" href="/dashboard/calendar">View calendar</a>
          </div>
        </article>
        <article class="card real-form-card handoff-form-card">
          <div class="card-head"><div><span class="kicker">handoff / auto mode</span><h3>Generate posts automatically</h3><p>Use the restored handoff flow inside the dashboard instead of an old standalone page.</p></div><button class="btn btn-ghost" type="button" data-full-composer>One-off post</button></div>
          <% if (!brands.length) { %><p class="empty-state">Create a brand first before generating handoff posts.</p><% } else { %>
            <form action="/posts/handoff" method="post" class="real-form-grid composer-form handoff-dashboard-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="generateImages" value="on">
              <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
              <label>Schedule<select name="frequencyUnit"><option value="day">Use daily plan</option><option value="week" selected>Use weekly plan</option><option value="month">Use monthly plan</option></select></label>
              <label>Start date<input type="date" name="startDate"></label>
              <label>Strength target<input type="number" name="strengthTarget" min="80" max="100" value="90"></label>
              <fieldset class="composer-fieldset full"><legend>Destination override</legend><div class="composer-check-grid channel-spaced-grid">
                <% socialAccounts.forEach((account) => { %>
                  <label class="composer-check-card target-account-option" data-brand="<%= account.brandId || '' %>" data-platform="<%= account.platform %>"><input name="targetAccounts" type="checkbox" value="<%= account.id %>"><span><strong><%= account.accountName %></strong><small><%= account.platform %> / <%= account.brandName || 'Workspace' %></small></span></label>
                <% }) %>
                <% if (!socialAccounts.length) { %><p class="muted">No connected accounts yet. Connect accounts from Social first.</p><% } %>
              </div></fieldset>
              <fieldset class="composer-fieldset full"><legend>Platforms</legend><div class="composer-check-grid compact-checkboxes">
                <% platforms.forEach((platform) => { %><label class="composer-check-card"><input name="platforms" type="checkbox" value="<%= platform %>" <%= platform === 'facebook' ? 'checked' : '' %>><span><strong><%= platform.replace(/_/g, ' ') %></strong><small>Use Brand Brain language</small></span></label><% }) %>
              </div></fieldset>
              <details class="composer-fieldset full"><summary>Brand Brain overrides</summary><div class="real-form-grid nested-grid">
                <label>Posts per day<input type="number" name="postsPerDay" min="1" max="12" value="1"></label>
                <label>Posts per week<input type="number" name="postsPerWeek" min="1" max="60" value="7"></label>
                <label>Posts per month<input type="number" name="postsPerMonth" min="1" max="90" value="30"></label>
                <label>Image size<select name="imageSize"><option value="1024x1024">Square feed</option><option value="1024x1536">Portrait</option><option value="1536x1024">Landscape</option></select></label>
                <label>Min images<input type="number" name="imagesPerPostMin" min="1" max="5" value="1"></label>
                <label>Max images/slides<input type="number" name="imagesPerPostMax" min="1" max="5" value="3"></label>
                <label class="full">Preferred time slots<input name="preferredSlots" value="morning, evening"></label>
                <label class="full">Customer goal<input name="customerGoal" value="get customers immediately with clear offers, proof, and a direct call to action"></label>
              </div></details>
              <div class="real-form-actions full"><button class="btn btn-primary" type="submit">Generate and schedule</button><a class="btn btn-ghost" href="/dashboard/brand-brain">Edit Brand Brain</a></div>
            </form>
          <% } %>
        </article>
      </section>
    </template>

    <template id="dashboard-form-team">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Team management</h3><p>Invite members and then manage status, roles and permissions on the team workspace.</p></div><a class="btn btn-primary" href="/dashboard/team">Team workspace</a></div>
        <% if (!brands.length) { %><p class="empty-state">Create a brand before inviting team members.</p><% } else { %>
          <form action="/team/invite" method="post" class="real-form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label>Name<input name="name" placeholder="Team member name"></label>
            <label>Email<input name="email" type="email" required placeholder="member@example.com"></label>
            <label>Role<select name="role"><option value="viewer">Viewer</option><option value="reviewer">Reviewer</option><option value="editor">Editor</option><option value="content_creator">Content creator</option><option value="manager">Manager</option><option value="admin">Admin</option></select></label>
            <label>Brand<select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand.id %>"><%= brand.name %></option><% }) %></select></label>
            <fieldset class="composer-fieldset full">
              <legend>Permissions</legend>
              <div class="composer-check-grid">
                <% ['brand_read', 'content_create', 'content_edit', 'schedule_posts', 'approve_posts', 'analytics_read'].forEach((permission) => { %>
                  <label class="composer-check-card"><input name="permissions" type="checkbox" value="<%= permission %>"><span><strong><%= permission.replace(/_/g, ' ') %></strong><small>Team permission</small></span></label>
                <% }) %>
              </div>
            </fieldset>
            <button class="btn btn-primary full" type="submit">Invite member</button>
          </form>
        <% } %>
      </article>
    </template>

    <template id="dashboard-form-analytics">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Analytics workspace</h3><p>Use the real analytics report while keeping live metrics visible in this dashboard.</p></div><a class="btn btn-primary" href="/dashboard/analytics">Analytics workspace</a></div>
        <div class="data-list">
          <div class="data-row"><div><strong>Performance reports</strong><span>Track published posts, platform results and campaign totals.</span></div><span class="badge">Live</span></div>
          <div class="data-row"><div><strong>Brand-level insights</strong><span>Use Brand Brain data to compare products, offers and channels.</span></div><span class="badge">Database</span></div>
        </div>
      </article>
    </template>

    <template id="dashboard-form-notifications">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Notification center</h3><p>Alerts from publishing, approvals and workspace activity are now reachable from the clean dashboard.</p></div><a class="btn btn-primary" href="/dashboard/notifications">Notifications workspace</a></div>
        <form action="/notifications/read-all" method="post" class="real-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-ghost full" type="submit">Mark all notifications as read</button>
        </form>
      </article>
    </template>


    <template id="dashboard-form-plans">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Plan management is now inside the dashboard</h3><p>No old overlay page: create, edit, duplicate, activate, deactivate and seed plans from this clean dashboard section.</p></div><a class="btn btn-primary" href="/dashboard/plans?mode=create">Create plan</a></div>
      </article>
    </template>

    <template id="dashboard-form-admin">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Admin console shortcut</h3><p>Super-admin tools are available here: plans, users, failed posts, API logs, audit logs and payments remain available.</p></div><a class="btn btn-primary" href="/dashboard/plans">Open plan page</a></div>
        <div class="data-list">
          <div class="data-row"><div><strong>Subscription plan management</strong><span>Create, edit, duplicate, reorder, activate and deactivate plans from the production admin page.</span></div><a class="badge" href="/dashboard/plans">Plans</a></div>
          <div class="data-row"><div><strong>User & subscription management</strong><span>Use the admin workspace for account status and plan control.</span></div><span class="badge">Admin</span></div>
          <div class="data-row"><div><strong>Failed publishing retry</strong><span>Retry failed posts through the existing admin backend.</span></div><span class="badge">Retry</span></div>
          <div class="data-row"><div><strong>Audit/API/payment logs</strong><span>Review operational records from the existing models.</span></div><span class="badge">Logs</span></div>
        </div>
      </article>
    </template>

    <template id="dashboard-form-billing"></template>

    <template id="dashboard-form-settings">
      <article class="card real-form-card">
        <div class="card-head"><div><h3>Workspace settings</h3><p>Quick access to the existing settings, provider health and diagnostics workflow.</p></div><a class="btn btn-primary" href="/dashboard/settings">Settings workspace</a></div>
        <form action="/settings/diagnostics" method="post" class="real-form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="full">Diagnostics scope<input name="scope" value="providers, queues, storage, social"></label>
          <button class="btn btn-ghost full" type="submit">Check workspace</button>
        </form>
      </article>
    </template>

  </div>

  <div class="modal-backdrop" id="modalBackdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-head">
        <div>
          <span class="modal-kicker" id="modalKicker">View</span>
          <h2 id="modalTitle">Record preview</h2>
        </div>
        <button class="icon-btn" id="modalClose" type="button" aria-label="Close modal"><svg class="icon"><use href="#icon-x"></use></svg></button>
      </div>
      <div class="modal-body" id="modalBody"></div>
      <div class="modal-actions" id="modalActions"></div>
    </div>
  </div>

  <script>
    window.__AUTOBRAND_DASHBOARD_DATA__ = <%- dashboardJson %>;
  </script>
    <script src="/js/brand-logo-upload.js?v=20260524-upload-intent"></script>
  <script src="/js/composer-intent.js?v=20260524-smart-output"></script>
  <script src="/js/dashboard-experience.js?v=20260606-complete-local-flows"></script>
</body>
</html>
