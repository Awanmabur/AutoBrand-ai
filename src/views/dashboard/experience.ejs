<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> &middot; AutoBrand AI</title>
  <link rel="stylesheet" href="/css/dashboard-experience.css?v=20260606-complete-local-flows" />
</head>
<body>
  <% const options = dashboardData.options || {}; %>
  <% const brands = options.brands || []; %>
  <% const visibleDashboardPages = dashboardData.roleAccess && Array.isArray(dashboardData.roleAccess.unlockedPages) ? dashboardData.roleAccess.unlockedPages : []; %>
  <% const canSeePage = (page) => visibleDashboardPages.includes(page); %>
  <% const canSeeDashboardPlans = visibleDashboardPages.includes('plans') || (dashboardData.user && /Admin/i.test(dashboardData.user.role || '')); %>
  <% const socialAccounts = options.socialAccounts || []; %>
  <% const mediaAssets = options.media || []; %>
  <% const platforms = ['facebook', 'instagram', 'google_business', 'linkedin', 'pinterest', 'tiktok', 'youtube', 'x', 'threads', 'whatsapp']; %>
  <% const composerBrands = brands.map((brand) => ({ _id: brand.id, name: brand.name })); %>
  <% const composerSocialAccounts = socialAccounts.map((account) => ({
    _id: account.id,
    platform: account.platform,
    accountName: account.accountName,
    brand: { _id: account.brandId || '', name: account.brandName || 'Workspace' }
  })); %>
  <% const composerMedia = mediaAssets.map((asset) => ({
    _id: asset.id,
    fileName: asset.fileName || 'Media asset',
    fileType: asset.fileType || 'image',
    mimeType: asset.mimeType || '',
    fileUrl: asset.fileUrl || '',
    brand: { _id: asset.brandId || '', name: asset.brandName || 'Brand asset' }
  })); %>
  <% const composerForm = {}; %>
  <% const composerContentGoals = ['awareness', 'engagement', 'sales', 'traffic', 'lead_generation', 'community', 'customer_support', 'launch', 'event', 'other']; %>
  <% const composerPostTypes = ['text', 'image', 'video', 'reel', 'story', 'carousel', 'article', 'campaign']; %>
  <% const composerContentTypes = ['promo', 'educational', 'testimonial', 'offer', 'product', 'announcement', 'engagement', 'behind_the_scenes', 'proof', 'faq', 'launch']; %>

