<section class="workspace-hero compact-hero">
  <div>
    <p class="eyebrow">settings</p>
    <h2>System setup and advanced tools</h2>
    <p>Keep the main sidebar clean. Advanced features remain available here for future expansion.</p>
  </div>
  <form action="/settings/diagnostics" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button" type="submit">Run diagnostics</button></form>
</section>

<section class="panel">
  <div class="section-heading-row"><div><p class="eyebrow">core readiness</p><h2>Provider readiness</h2><p class="muted">These checks show which external services are configured and reachable.</p></div></div>
  <div class="item-grid settings-card-grid">
    <% configs.forEach((config) => { %>
      <article class="item-card">
        <h2><%= config.name %></h2>
        <p><%= config.keys.join(', ') %></p>
        <span class="status-pill"><%= config.ready ? 'configured' : 'missing keys' %></span>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-heading-row"><div><p class="eyebrow">advanced modules</p><h2>Available but not in the main sidebar</h2><p class="muted">Use these when you need them. The daily workflow stays focused on Create Post, Calendar, Brands, Media and Channels.</p></div></div>
  <div class="command-grid secondary-tools-grid">
    <a class="command-card" href="/ai/generator"><span>AI</span><h3>AI Generator</h3><p>Standalone text generator for experiments outside the post studio.</p></a>
    <a class="command-card" href="/campaigns"><span>CP</span><h3>Campaigns</h3><p>Longer campaign planning and draft creation.</p></a>
    <a class="command-card" href="/growth-studio"><span>GR</span><h3>Growth Studio</h3><p>Growth experiments and content ideas.</p></a>
    <a class="command-card" href="/videos"><span>VI</span><h3>AI Videos</h3><p>Video jobs and scripts.</p></a>
    <a class="command-card" href="/templates"><span>TE</span><h3>Templates</h3><p>Reusable creative templates.</p></a>
    <a class="command-card" href="/avatars"><span>AV</span><h3>Avatars</h3><p>Avatar and consent workflows.</p></a>
    <a class="command-card" href="/approvals"><span>OK</span><h3>Approvals</h3><p>Review workflows for teams.</p></a>
    <a class="command-card" href="/team"><span>TM</span><h3>Team</h3><p>Invite and manage collaborators.</p></a>
    <a class="command-card" href="/billing"><span>$</span><h3>Billing</h3><p>Plans, limits and payments.</p></a>
    <a class="command-card" href="/notifications"><span>NT</span><h3>Notifications</h3><p>System and publishing alerts.</p></a>
  </div>
</section>

<% if (results) { %>
  <section class="panel">
    <h2>Diagnostic results</h2>
    <% results.forEach((result) => { %>
      <article class="job-card">
        <div><h3><%= result.provider %></h3><p><%= result.message %></p></div>
        <span><%= result.ok ? 'ok' : result.configured ? 'failed' : 'skipped' %></span>
      </article>
    <% }) %>
  </section>
<% } %>

<section class="panel">
  <h2>Recent API logs</h2>
  <% if (!logs.length) { %><p class="muted">No provider checks yet.</p><% } %>
  <% logs.forEach((log) => { %>
    <article class="job-card"><div><h3><%= log.provider %> / <%= log.action %></h3><p><%= log.message || 'No message' %></p></div><span><%= log.status %></span></article>
  <% }) %>
</section>
