<section class="workspace-hero compact-hero">
  <div>
    <p class="eyebrow">content library</p>
    <h2>All posts, drafts, schedules and results</h2>
    <p>Use this page as the single archive for everything you create. Drafts, scheduled posts, published posts and failed posts stay together.</p>
  </div>
  <div class="row-actions wrap"><a class="button" href="/dashboard/quick-create">Create post</a><a class="button ghost" href="/dashboard/calendar">Calendar</a></div>
</section>

<section class="stats-grid compact-stats">
  <article class="stat-card"><span>Total</span><strong><%= stats.total %></strong></article>
  <article class="stat-card"><span>Drafts</span><strong><%= stats.draft %></strong></article>
  <article class="stat-card"><span>Scheduled</span><strong><%= stats.scheduled %></strong></article>
  <article class="stat-card"><span>Published</span><strong><%= stats.published %></strong></article>
</section>

<section class="panel">
  <form action="/posts/drafts" method="get" class="form-grid library-filter-form">
    <label>Status
      <select name="status">
        <option value="">All statuses</option>
        <% ['draft', 'scheduled', 'publishing', 'published', 'failed', 'cancelled'].forEach((status) => { %>
          <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
        <% }) %>
      </select>
    </label>
    <label>Brand
      <select name="brand">
        <option value="">All brands</option>
        <% brands.forEach((brand) => { %>
          <option value="<%= brand._id %>" <%= filters.brand === String(brand._id) ? 'selected' : '' %>><%= brand.name %></option>
        <% }) %>
      </select>
    </label>
    <label>Platform
      <select name="platform">
        <option value="">All platforms</option>
        <% ['facebook', 'instagram', 'tiktok', 'youtube', 'whatsapp', 'linkedin', 'x', 'pinterest'].forEach((platform) => { %>
          <option value="<%= platform %>" <%= filters.platform === platform ? 'selected' : '' %>><%= platform %></option>
        <% }) %>
      </select>
    </label>
    <button class="button ghost" type="submit">Filter</button>
  </form>
</section>

<section class="post-list library-list">
  <% if (!posts.length) { %>
    <article class="empty-state"><h2>No posts found</h2><p>Create a new post or clear the filters.</p><a class="button" href="/dashboard/quick-create">Create post</a></article>
  <% } %>
  <% posts.forEach((post) => { %>
    <article class="post-row library-row">
      <div>
        <p class="eyebrow"><%= post.brand ? post.brand.name : 'Missing brand' %> / <%= post.platform %></p>
        <h2><%= post.title || 'Untitled post' %></h2>
        <p><%= post.caption %></p>
        <% if (post.hashtags && post.hashtags.length) { %><p class="muted"><%= post.hashtags.join(' ') %></p><% } %>
        <% if (post.targetAccounts?.length) { %><p class="muted"><strong>Pages:</strong> <%= post.targetAccounts.map((account) => account.accountName).join(', ') %></p><% } %>
        <% if (post.scheduledAt) { %><p class="muted"><strong>Scheduled:</strong> <%= post.scheduledAt.toLocaleString() %></p><% } %>
      </div>
      <div class="stack-actions">
        <span class="status-pill"><%= post.status %></span>
        <a class="button ghost" href="/posts/<%= post._id %>/edit">Open</a>
        <form action="/posts/<%= post._id %>/duplicate" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button ghost" type="submit">Duplicate</button></form>
        <form action="/posts/<%= post._id %>?_method=DELETE" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button ghost" type="submit">Delete</button></form>
      </div>
    </article>
  <% }) %>
</section>
