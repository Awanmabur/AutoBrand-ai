<section class="panel">
  <p class="eyebrow"><%= post.brand.name %></p>
  <h2>Edit draft</h2>
  <% if (error) { %><p class="form-error"><%= error %></p><% } %>
  <form action="/posts/<%= post._id %>?_method=PUT" method="post" class="form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title <input name="title" value="<%= post.title || '' %>"></label>
    <label>Platform
      <select name="platform">
        <% ['facebook', 'instagram', 'tiktok', 'youtube', 'whatsapp', 'linkedin', 'x', 'pinterest'].forEach((platform) => { %>
          <option value="<%= platform %>" <%= post.platform === platform ? 'selected' : '' %>><%= platform %></option>
        <% }) %>
      </select>
    </label>
    <label>Post type
      <select name="type">
        <% ['text', 'image', 'carousel', 'video'].forEach((type) => { %>
          <option value="<%= type %>" <%= post.type === type ? 'selected' : '' %>><%= type %></option>
        <% }) %>
      </select>
    </label>
    <label>Link <input name="link" value="<%= post.link || '' %>"></label>
    <label class="span-2">Caption <textarea name="caption" rows="7" required><%= post.caption %></textarea></label>
    <label class="span-2">Description <textarea name="description" rows="3" placeholder="YouTube, Pinterest, or LinkedIn description"><%= post.description || '' %></textarea></label>
    <label class="span-2">Hashtags <textarea name="hashtags" rows="3"><%= post.hashtags.join(' ') %></textarea></label>

    <fieldset class="span-2 fieldset">
      <legend>Publish destinations</legend>
      <% if (!socialAccounts.length) { %><p class="muted">No connected accounts for this brand/platform yet.</p><% } %>
      <% socialAccounts.forEach((account) => { %>
        <label class="checkbox-row">
          <input name="targetAccounts" type="checkbox" value="<%= account._id %>" <%= post.targetAccounts?.some((selected) => selected._id.toString() === account._id.toString()) ? 'checked' : '' %>>
          <span><strong><%= account.accountName %></strong> <small><%= account.platform %></small></span>
        </label>
      <% }) %>
    </fieldset>

    <fieldset class="span-2 fieldset">
      <legend>Media</legend>
      <% if (!media.length) { %><p class="muted">No media for this brand yet.</p><% } %>
      <div class="media-picker-grid">
        <% media.forEach((item) => { %>
          <label class="media-picker-card">
            <input name="media" type="checkbox" value="<%= item._id %>" <%= post.media.some((selected) => selected._id.toString() === item._id.toString()) ? 'checked' : '' %>>
            <% if (item.fileType === 'image') { %><img src="<%= item.fileUrl %>" alt=""><% } else if (item.fileType === 'video') { %><video src="<%= item.fileUrl %>" controls preload="metadata" playsinline></video><% } else { %><span class="media-placeholder"><%= item.fileType %></span><% } %>
            <span><%= item.fileName %></span>
          </label>
        <% }) %>
      </div>
    </fieldset>

    <fieldset class="span-2 fieldset">
      <legend>AI creative plan</legend>
      <label class="span-2">Image prompt
        <textarea name="imagePrompt" rows="4"><%= post.platformMetadata?.imagePrompt || '' %></textarea>
      </label>
      <label class="span-2">Video script / prompt
        <textarea name="videoScript" rows="5"><%= post.platformMetadata?.videoScript || post.platformMetadata?.videoPrompt || '' %></textarea>
      </label>
      <% if (post.platformMetadata?.generatedScore) { %>
        <p class="muted span-2"><strong>AI score:</strong> <%= post.platformMetadata.generatedScore %> / 100. <%= post.platformMetadata.improvementSuggestion || '' %></p>
      <% } %>
    </fieldset>
    <button class="button" type="submit">Save draft</button>
  </form>
</section>

<section class="panel">
  <p class="eyebrow"><%= preview.platform %> preview</p>
  <h2><%= preview.title || 'Untitled post' %></h2>
  <p><%= preview.caption %></p>
  <% if (preview.hashtags.length) { %><p><strong>Hashtags:</strong> <%= preview.hashtags.join(' ') %></p><% } %>
  <% if (preview.link) { %><p><strong>Link:</strong> <%= preview.link %></p><% } %>
  <% if (post.media && post.media.length) { %>
    <div class="post-media-preview-grid">
      <% post.media.forEach((item) => { %>
        <% if (item.fileType === 'image') { %>
          <img src="<%= item.fileUrl %>" alt="<%= item.fileName || 'Post image' %>">
        <% } else if (item.fileType === 'video') { %>
          <video src="<%= item.fileUrl %>" controls preload="metadata" playsinline></video>
        <% } else { %>
          <div class="media-placeholder"><%= item.fileType %></div>
        <% } %>
      <% }) %>
    </div>
  <% } %>
  <div class="detail-list">
    <div><strong>Title</strong><p class="muted"><%= preview.titleCount %>/<%= preview.titleLimit %> recommended characters</p></div>
    <div><strong>Caption</strong><p class="muted"><%= preview.captionCount %>/<%= preview.captionLimit %> max characters</p></div>
    <div><strong>Tip</strong><p class="muted"><%= preview.tip %></p></div>
  </div>
  <% if (preview.warnings.length) { %>
    <ul class="clean-list warning-list">
      <% preview.warnings.forEach((warning) => { %><li><%= warning %></li><% }) %>
    </ul>
  <% } %>
</section>

<section class="panel">
  <h2>Schedule</h2>
  <form action="/posts/<%= post._id %>/schedule" method="post" class="form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Publish date and time <input name="scheduledAt" type="datetime-local" required></label>
    <button class="button" type="submit">Schedule post</button>
  </form>
</section>

<section class="panel">
  <h2>Actions</h2>
  <div class="nav-actions wrap">
    <form action="/posts/<%= post._id %>/duplicate" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <select name="platform">
        <% ['facebook', 'instagram', 'tiktok', 'youtube', 'whatsapp', 'linkedin', 'x', 'pinterest'].forEach((platform) => { %>
          <option value="<%= platform %>" <%= post.platform === platform ? 'selected' : '' %>><%= platform %></option>
        <% }) %>
      </select>
      <button class="button ghost" type="submit">Duplicate</button>
    </form>
    <form action="/posts/<%= post._id %>/publish-now" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="button ghost" type="submit">Publish now</button>
    </form>
    <form action="/posts/<%= post._id %>/cancel" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="button ghost" type="submit">Cancel</button>
    </form>
  </div>
</section>
