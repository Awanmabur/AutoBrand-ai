<section class="workspace-hero compact-hero">
  <div>
    <p class="eyebrow">automatic posting</p>
    <h2>Generate the schedule from Brand Brain</h2>
    <p>Pick the brand and run it. AutoBrand uses saved frequency, slots, media mix, customer goal, platform language, products, offers, proof, and rules.</p>
  </div>
  <div class="hero-action-card">
    <strong>Media first</strong>
    <p>Images and carousel slides are generated automatically. Video requests fall back to storyboard slides when no renderer is configured.</p>
    <a class="button ghost" href="/dashboard/calendar">View calendar</a>
  </div>
</section>

<section class="panel">
  <div class="section-heading-row">
    <div>
      <p class="eyebrow">auto campaign</p>
      <h2>Generate posts automatically</h2>
    </div>
    <a class="button ghost" href="/dashboard/quick-create">Create one post</a>
  </div>

  <% if (error) { %><p class="form-error"><%= error %></p><% } %>
  <% if (typeof providerMessage !== 'undefined' && providerMessage) { %><p class="form-error">AI fallback: <%= providerMessage %></p><% } %>

  <form action="/posts/handoff" method="post" class="form-grid composer-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label>Brand
      <select name="brand" required>
        <% brands.forEach((brand) => { %>
          <option value="<%= brand._id %>" <%= String(form.brand || activeBrandId) === String(brand._id) ? 'selected' : '' %>><%= brand.name %></option>
        <% }) %>
      </select>
    </label>

    <input type="hidden" name="generateImages" value="on">

    <details class="span-2 fieldset">
      <summary>Destination override</summary>
      <% const chosenAccounts = Array.isArray(form.targetAccounts) ? form.targetAccounts : form.targetAccounts ? [form.targetAccounts] : []; %>
      <% if (!socialAccounts.length) { %><p class="muted">No connected accounts yet. Connect Facebook Pages from Social first.</p><% } %>
      <% socialAccounts.forEach((account) => { %>
        <label class="checkbox-row target-account-option" data-brand="<%= account.brand._id %>" data-platform="<%= account.platform %>">
          <input name="targetAccounts" type="checkbox" value="<%= account._id %>" <%= chosenAccounts.includes(String(account._id)) ? 'checked' : '' %>>
          <span><strong><%= account.accountName %></strong> <small><%= account.platform %> / <%= account.brand.name %></small></span>
        </label>
      <% }) %>
    </details>

    <details class="span-2 fieldset">
      <summary>Schedule and platform override</summary>
      <label>Schedule
        <select name="frequencyUnit">
          <option value="day" <%= form.frequencyUnit === 'day' ? 'selected' : '' %>>Use daily plan</option>
          <option value="week" <%= form.frequencyUnit !== 'day' && form.frequencyUnit !== 'month' ? 'selected' : '' %>>Use weekly plan</option>
          <option value="month" <%= form.frequencyUnit === 'month' ? 'selected' : '' %>>Use monthly plan</option>
        </select>
      </label>
      <label>Start date <input type="date" name="startDate" value="<%= form.startDate || '' %>"></label>
      <div class="checkbox-grid compact-checkboxes span-2">
        <% platforms.forEach((platform) => { %>
          <label class="checkbox-row"><input name="platforms" type="checkbox" value="<%= platform %>" <%= (Array.isArray(form.platforms) ? form.platforms : [form.platforms || 'facebook']).includes(platform) ? 'checked' : '' %>> <span><%= platform %></span></label>
        <% }) %>
      </div>
    </details>

    <details class="span-2 fieldset">
      <summary>Brand Brain overrides</summary>
      <label>Posts per day <input type="number" name="postsPerDay" min="1" max="12" value="<%= form.postsPerDay || 1 %>"></label>
      <label>Posts per week <input type="number" name="postsPerWeek" min="1" max="60" value="<%= form.postsPerWeek || 7 %>"></label>
      <label>Posts per month <input type="number" name="postsPerMonth" min="1" max="90" value="<%= form.postsPerMonth || 30 %>"></label>
      <label class="span-2">Preferred time slots
        <input name="preferredSlots" value="<%= Array.isArray(form.preferredSlots) ? form.preferredSlots.join(', ') : (form.preferredSlots || 'morning, evening') %>">
      </label>
      <label>Strength target <input type="number" name="strengthTarget" min="80" max="100" value="<%= form.strengthTarget || 90 %>"></label>
      <label>Image size
        <select name="imageSize">
          <option value="1024x1024">Square feed</option>
          <option value="1024x1536">Portrait</option>
          <option value="1536x1024">Landscape</option>
        </select>
      </label>
      <label>Min images <input type="number" name="imagesPerPostMin" min="1" max="5" value="<%= form.imagesPerPostMin || 1 %>"></label>
      <label>Max images/slides <input type="number" name="imagesPerPostMax" min="1" max="5" value="<%= form.imagesPerPostMax || 3 %>"></label>
      <label class="span-2">Customer goal
        <input name="customerGoal" value="<%= form.customerGoal || 'get customers immediately with clear offers, proof, and a direct call to action' %>">
      </label>
      <div class="checkbox-grid span-2 compact-checkboxes">
        <% ['auto','image','slides','video','text'].forEach((item) => { %>
          <label class="checkbox-row"><input name="mediaMix" type="checkbox" value="<%= item %>" <%= (Array.isArray(form.mediaMix) ? form.mediaMix : ['auto','image','slides','video']).includes(item) ? 'checked' : '' %>> <span><%= item %></span></label>
        <% }) %>
      </div>
      <div class="checkbox-grid compact-checkboxes span-2">
        <% contentTypes.forEach((type) => { %>
          <label class="checkbox-row"><input name="contentMix" type="checkbox" value="<%= type %>" <%= (Array.isArray(form.contentMix) ? form.contentMix : ['promo','educational','testimonial','offer','faq']).includes(type) ? 'checked' : '' %>> <span><%= type.replace(/_/g, ' ') %></span></label>
        <% }) %>
      </div>
    </details>

    <div class="composer-actions span-2">
      <button class="button" type="submit">Generate and schedule</button>
      <a class="button ghost" href="/brands">Edit Brand Brain</a>
    </div>
  </form>
</section>

<% if (createdPosts && createdPosts.length) { %>
  <section class="panel">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">campaign created</p>
        <h2><%= typeof campaignTitle !== 'undefined' ? campaignTitle : 'Auto campaign scheduled' %></h2>
        <% if (typeof strategySummary !== 'undefined' && strategySummary) { %><p><%= strategySummary %></p><% } %>
      </div>
      <a class="button" href="/dashboard/calendar">Open calendar</a>
    </div>
    <div class="post-list">
      <% createdPosts.forEach((post) => { %>
        <article class="post-row-card">
          <div>
            <strong><%= post.title %></strong>
            <p><%= post.caption %></p>
            <small><%= post.platform %> / <%= post.status %> / <%= post.scheduledAt ? new Date(post.scheduledAt).toLocaleString() : 'draft' %></small>
          </div>
          <a class="button ghost" href="/posts/<%= post._id %>/edit">Review</a>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<script>
  (function () {
    const brandSelect = document.querySelector('select[name="brand"]');
    const accountOptions = Array.from(document.querySelectorAll('.target-account-option'));
    function syncBrandFilters() {
      const brand = brandSelect ? brandSelect.value : '';
      accountOptions.forEach((item) => {
        item.style.display = !brand || item.dataset.brand === brand ? '' : 'none';
      });
    }
    brandSelect?.addEventListener('change', syncBrandFilters);
    syncBrandFilters();
  })();
</script>
