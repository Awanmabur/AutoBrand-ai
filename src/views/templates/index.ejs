<section class="panel">
  <p class="eyebrow">Template videos</p>
  <h2>Cheap video render queue</h2>
  <p>Create a template video manifest from brand data, offers, logos, CTA, phone, and website. Final MP4 rendering can be attached to a worker/provider later.</p>
  <% if (error) { %><p class="form-error"><%= error %></p><% } %>
  <% if (!brands.length) { %>
    <p class="form-error">Create a Brand Brain first.</p>
  <% } else { %>
    <form action="/templates/render" method="post" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand
        <select name="brand" required>
          <% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %>
        </select>
      </label>
      <label>Template
        <select name="template" required>
          <% templates.forEach((template) => { %>
            <option value="<%= template._id %>"><%= template.name %> - <%= template.aspectRatio %></option>
          <% }) %>
        </select>
      </label>
      <label>Headline <input name="headline" placeholder="Weekend flash sale"></label>
      <label>Offer <input name="offer" placeholder="50% off selected packages"></label>
      <label>Price <input name="price" placeholder="UGX 10,000"></label>
      <label>CTA <input name="cta" placeholder="Order on WhatsApp today"></label>
      <label>Phone <input name="phone" placeholder="+256..."></label>
      <label>Website <input name="website" placeholder="https://..."></label>
      <label class="span-2">Style <input name="style" placeholder="clean, fast, local"></label>
      <button class="button" type="submit">Queue render</button>
    </form>
  <% } %>
</section>

<section class="feature-grid">
  <% templates.forEach((template) => { %>
    <article class="feature-card">
      <strong><%= template.name %></strong>
      <p><%= template.category.replace(/_/g, ' ') %> / <%= template.aspectRatio %> / <%= template.durationSeconds %>s</p>
      <p><%= template.scenes.map((scene) => scene.name).join(', ') %></p>
    </article>
  <% }) %>
</section>

<section class="panel">
  <h2>Render queue</h2>
  <% if (!renders.length) { %>
    <p class="muted">No template renders yet.</p>
  <% } %>
  <% renders.forEach((render) => { %>
    <article class="job-card">
      <div>
        <p class="eyebrow"><%= render.brand.name %> - <%= render.template ? render.template.name : 'template' %></p>
        <h3><%= render.inputData.headline %></h3>
        <p><%= render.inputData.offer %></p>
        <p class="muted"><%= render.costCredits %> credits / <%= render.inputData.aspectRatio %></p>
        <% if (render.outputUrl) { %><p><a href="<%= render.outputUrl %>">Output URL</a></p><% } %>
      </div>
      <div class="stack-actions">
        <form action="/templates/renders/<%= render._id %>/status" method="post" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="status">
            <% ['queued', 'rendering', 'ready', 'failed', 'cancelled'].forEach((status) => { %>
              <option value="<%= status %>" <%= render.status === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
          <input name="outputUrl" placeholder="Optional output URL" value="<%= render.outputUrl || '' %>">
          <button class="button ghost" type="submit">Update</button>
        </form>
        <form action="/templates/renders/<%= render._id %>/create-post" method="post" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="platform">
            <option value="instagram">Instagram</option>
            <option value="tiktok">TikTok</option>
            <option value="youtube">YouTube Shorts</option>
            <option value="facebook">Facebook</option>
            <option value="whatsapp">WhatsApp</option>
          </select>
          <button class="button ghost" type="submit">Create video draft</button>
        </form>
      </div>
    </article>
  <% }) %>
</section>
