<div class="section-kicker">Create account</div>
<h1>Start free today.</h1>
<p>Create your account and begin building content campaigns with your AI brand assistant.</p>

<% if (typeof selectedPlan !== 'undefined' && selectedPlan) { %>
  <div class="auth-plan-card">
    <strong>Selected plan: <%= selectedPlan.name %></strong>
    <span><%= selectedPlan.priceLabel %><% if (!selectedPlan.isTrial) { %>/<%= selectedPlan.intervalLabel %><% } %></span>
    <a href="/pricing">Change plan</a>
  </div>
<% } %>

<% if (error) { %><p class="form-error"><%= error %></p><% } %>

<a class="google-auth-btn" href="/auth/google<%= form.plan ? `?plan=${encodeURIComponent(form.plan)}` : '' %><%= form.next ? `${form.plan ? '&' : '?'}next=${encodeURIComponent(form.next)}` : '' %>">
  <span class="google-icon" aria-hidden="true">
    <svg viewBox="0 0 48 48" role="img">
      <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.4-.4-3.5z"/>
      <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15.1 19 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.1 6.1 29.3 4 24 4 16.3 4 9.6 8.3 6.3 14.7z"/>
      <path fill="#4CAF50" d="M24 44c5.1 0 9.8-2 13.3-5.2l-6.1-5.2C29.2 35.1 26.7 36 24 36c-5.2 0-9.6-3.3-11.3-7.9l-6.5 5C9.4 39.5 16.1 44 24 44z"/>
      <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.1 5.6l6.1 5.2C36.9 39.1 44 34 44 24c0-1.3-.1-2.4-.4-3.5z"/>
    </svg>
  </span>
  Sign up with Google
</a>

<div class="auth-divider">or create with email</div>

<form action="/auth/register" method="post" class="auth-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <input type="hidden" name="plan" value="<%= form.plan || (typeof selectedPlan !== 'undefined' && selectedPlan ? selectedPlan.slug : 'free-trial') %>">
  <input type="hidden" name="next" value="<%= form.next || (typeof selectedPlan !== 'undefined' && selectedPlan ? selectedPlan.checkoutUrl : '/dashboard') %>">
  <input name="name" value="<%= form.name || '' %>" placeholder="Full name" autocomplete="name" aria-label="Full name" required>
  <input name="email" type="email" value="<%= form.email || '' %>" placeholder="Email address" autocomplete="email" aria-label="Email address" required>
  <input name="password" type="password" minlength="8" placeholder="Create password" autocomplete="new-password" aria-label="Create password" required>
  <button class="btn btn-primary" type="submit">Create account</button>
</form>

<div class="auth-switch">Already have an account? <a href="/auth/login<%= form.next ? `?next=${encodeURIComponent(form.next)}` : '' %>">Login</a></div>
