<section class="panel">
  <h2>AI Generator</h2>
  <p>Create brand-aware captions, hashtags, image prompts, and video scripts. Generated posts are saved as drafts.</p>
  <% if (error) { %><p class="form-error"><%= error %></p><% } %>
  <% if (!brands.length) { %>
    <p class="form-error">Create a Brand Brain first so AI has context.</p>
  <% } else { %>
    <form action="/ai/generate-post" method="post" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand
        <select name="brand" required>
          <% brands.forEach((brand) => { %>
            <option value="<%= brand._id %>"><%= brand.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Platform
        <select name="platform">
          <option value="facebook">Facebook</option>
          <option value="instagram">Instagram</option>
          <option value="tiktok">TikTok</option>
          <option value="youtube">YouTube Shorts</option>
          <option value="whatsapp">WhatsApp</option>
          <option value="linkedin">LinkedIn</option>
        </select>
      </label>
      <label>Content type
        <select name="contentType">
          <option value="promo">Promo</option>
          <option value="offer">Offer</option>
          <option value="educational">Educational</option>
          <option value="event">Event</option>
          <option value="testimonial">Testimonial</option>
          <option value="blog_to_social">Blog to social</option>
          <option value="whatsapp_status">WhatsApp status</option>
          <option value="whatsapp_group_promo">WhatsApp group promo</option>
          <option value="real_estate">Real estate</option>
          <option value="restaurant_menu">Restaurant menu</option>
          <option value="church_event">Church event</option>
          <option value="internet_voucher">Internet voucher</option>
        </select>
      </label>
      <label>Goal <input name="goal" placeholder="Sell daily hotspot vouchers"></label>
      <label class="span-2">Use uploaded image/video
        <select name="sourceMedia">
          <option value="">No uploaded media</option>
          <% media.forEach((item) => { %>
            <option value="<%= item._id %>"><%= item.brand.name %> / <%= item.fileName %> (<%= item.fileType %>)</option>
          <% }) %>
        </select>
      </label>
      <button class="button" type="submit">Generate draft</button>
    </form>
  <% } %>
</section>

<section class="panel">
  <h2>AI quick tools</h2>
  <% if (!brands.length) { %>
    <p class="muted">Create a Brand Brain first.</p>
  <% } else { %>
    <div class="split-grid">
      <form action="/ai/generate-hashtags" method="post" class="form-stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>Brand
          <select name="brand" required>
            <% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %>
          </select>
        </label>
        <label>Goal <input name="goal" placeholder="Weekend promotion"></label>
        <button class="button ghost" type="submit">Generate hashtags</button>
      </form>
      <form action="/ai/generate-video-script" method="post" class="form-stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>Brand
          <select name="brand" required>
            <% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %>
          </select>
        </label>
        <label>Platform <input name="platform" value="Instagram Reels"></label>
        <label>Goal <input name="goal" placeholder="Sell a new offer"></label>
        <label>Offer <input name="offer" placeholder="50% weekend discount"></label>
        <label>Style <input name="style" placeholder="clean, bright, local"></label>
        <label>Use media
          <select name="sourceMedia">
            <option value="">No uploaded media</option>
            <% media.forEach((item) => { %>
              <option value="<%= item._id %>"><%= item.fileName %> (<%= item.fileType %>)</option>
            <% }) %>
          </select>
        </label>
        <button class="button ghost" type="submit">Generate video script</button>
      </form>
    </div>
    <form action="/ai/generate-campaign" method="post" class="form-grid section-subtitle">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Brand
        <select name="brand" required>
          <% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %>
        </select>
      </label>
      <label>Campaign name <input name="name" placeholder="Weekend sales push"></label>
      <label>Platforms <input name="platforms" value="facebook, instagram, tiktok"></label>
      <label>Duration days <input name="durationDays" type="number" min="1" max="30" value="7"></label>
      <label class="span-2">Goal <input name="goal" placeholder="Drive more WhatsApp orders"></label>
      <button class="button ghost" type="submit">Generate campaign</button>
    </form>
  <% } %>
</section>

<% if (toolResult) { %>
  <section class="panel">
    <p class="eyebrow">AI tool result</p>
    <h2><%= toolResult.title %></h2>
    <pre class="result-block"><%= toolResult.body %></pre>
    <% if (toolResult.notes && toolResult.notes.length) { %>
      <ul class="clean-list">
        <% toolResult.notes.forEach((note) => { %><li><%= note %></li><% }) %>
      </ul>
    <% } %>
  </section>
<% } %>

<% if (result) { %>
  <section class="panel">
    <p class="eyebrow">Generated draft</p>
    <h2><%= result.title %></h2>
    <p><%= result.caption %></p>
    <p><strong>Hashtags:</strong> <%= result.hashtags.join(' ') %></p>
    <p><strong>Image prompt:</strong> <%= result.imagePrompt %></p>
    <p><strong>Video script:</strong> <%= result.videoScript %></p>
    <p><strong>Description:</strong> <%= result.description %></p>
    <p><strong>YouTube tags:</strong> <%= result.youtubeTags.join(', ') %></p>
    <p><strong>Score:</strong> <%= result.contentScore %>/100 / <%= result.improvementSuggestion %></p>
  </section>
<% } %>

<section class="panel">
  <h2>Recent drafts</h2>
  <% if (!drafts.length) { %>
    <p class="muted">No drafts yet.</p>
  <% } %>
  <% drafts.forEach((draft) => { %>
    <article class="job-card">
      <div>
        <h3><%= draft.title || draft.platform %></h3>
        <p><%= draft.caption %></p>
      </div>
      <span><%= draft.brand.name %></span>
    </article>
  <% }) %>
</section>
