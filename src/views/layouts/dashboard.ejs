    <div class="drawer-backdrop" id="drawerBackdrop"></div>

    <aside class="sidebar" id="sidebar" aria-label="Dashboard sidebar">
      <div class="sidebar-top">
        <a class="brand" href="/dashboard">
          <span class="brand-logo">AB</span>
          <span><strong>AutoBrand AI</strong><small>Social SaaS</small></span>
        </a>
        <button class="icon-btn close-drawer" id="closeDrawer" type="button" aria-label="Close menu"><svg class="icon"><use href="#icon-x"></use></svg></button>
      </div>

      <div class="workspace-card">
        <span>Workspace</span>
        <strong><%= appName %></strong>
        <small>AI content, media, calendar and social APIs</small>
      </div>

      <div class="sidebar-scroll">
        <% navGroups.forEach((group) => { %>
          <p class="nav-label"><%= group.label %></p>
          <nav class="side-nav">
            <% group.links.forEach((link) => { %>
              <a class="<%= link.active ? 'active' : '' %>" href="<%= link.href %>">
                <span><svg class="icon"><use href="#icon-<%= link.icon %>"></use></svg><%= link.label %></span>
                <b><%= link.badge %></b>
              </a>
              <% if (group.label === 'Admin' && link.label === 'Settings') { %>
                <form class="side-nav-logout" action="/auth/logout" method="post">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="side-nav-button" type="submit"><span><svg class="icon"><use href="#icon-x"></use></svg>Logout</span><b>Exit</b></button>
                </form>
              <% } %>
            <% }) %>
          </nav>
        <% }) %>

        <div class="mobile-menu-actions" aria-label="Mobile account and theme controls">
          <button class="mobile-theme-toggle" id="themeToggleMenu" type="button" aria-label="Toggle theme">
            <svg class="icon mobile-theme-icon"><use href="#icon-moon"></use></svg>
            <strong>Dark mode</strong>
          </button>
          <div class="mobile-profile" aria-label="Current user">
            <span><%= initials %></span>
            <strong><%= firstName %></strong>
          </div>
        </div>

        <div class="upgrade-card">
          <strong>Upgrade to Studio</strong>
          <p>Unlock client approvals, AI video, avatar video, larger workspaces and premium exports.</p>
          <a class="btn btn-light" href="/dashboard/billing">View plan</a>
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <button class="icon-btn menu-btn" id="openDrawer" type="button" aria-label="Open menu"><svg class="icon"><use href="#icon-menu"></use></svg></button>
        <div class="top-title">
          <h1 id="pageTitle"><%= typeof title !== 'undefined' && title ? title : 'Dashboard' %></h1>
        </div>
        <div class="top-actions">
          <input class="search" type="search" placeholder="Search campaigns, brands, posts..." aria-label="Search">
          <button class="icon-btn" id="themeToggle" type="button" aria-label="Toggle theme"><svg class="icon"><use href="#icon-moon"></use></svg></button>
          <a class="btn btn-primary" href="/dashboard/quick-create"><svg class="icon"><use href="#icon-plus"></use></svg>Create</a>
          <div class="profile"><span><%= initials %></span><strong><%= firstName %></strong></div>
          <form action="/auth/logout" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="icon-btn" type="submit" aria-label="Logout"><svg class="icon"><use href="#icon-x"></use></svg></button>
          </form>
        </div>
      </header>

      <section class="page active">
        <%- body %>
      </section>
    </main>

    <div class="modal-backdrop detail-modal-backdrop" id="detailModalBackdrop" aria-hidden="true">
      <section class="modal detail-modal" role="dialog" aria-modal="true" aria-labelledby="detailModalTitle">
        <div class="modal-head">
          <div>
            <span class="modal-kicker" id="detailModalKicker">Details</span>
            <h2 id="detailModalTitle">Details</h2>
          </div>
          <button class="icon-btn" id="detailModalClose" type="button" aria-label="Close details"><svg class="icon"><use href="#icon-x"></use></svg></button>
        </div>
        <div class="modal-body" id="detailModalBody"></div>
      </section>
    </div>

    <script src="/js/theme.js"></script>
    <script nonce="<%= cspNonce %>">
      (() => {
        const body = document.body;
        const sidebar = document.getElementById('sidebar');
        const drawerBackdrop = document.getElementById('drawerBackdrop');
        const openDrawer = document.getElementById('openDrawer');
        const closeDrawer = document.getElementById('closeDrawer');
        const themeToggle = document.getElementById('themeToggle');
        const themeToggleMenu = document.getElementById('themeToggleMenu');
        const savedTheme = localStorage.getItem('autoBrandDashboardTheme');
        if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          body.classList.add('dark-mode');
        }
        const syncTheme = () => {
          const isDark = body.classList.contains('dark-mode');
          if (themeToggle) themeToggle.setAttribute('aria-label', isDark ? 'Use light mode' : 'Use dark mode');
          if (themeToggleMenu) {
            const label = themeToggleMenu.querySelector('strong');
            if (label) label.textContent = isDark ? 'Light mode' : 'Dark mode';
          }
        };
        const toggleTheme = () => {
          body.classList.toggle('dark-mode');
          localStorage.setItem('autoBrandDashboardTheme', body.classList.contains('dark-mode') ? 'dark' : 'light');
          syncTheme();
        };
        const showDrawer = () => {
          sidebar.classList.add('open');
          drawerBackdrop.classList.add('show');
        };
        const hideDrawer = () => {
          sidebar.classList.remove('open');
          drawerBackdrop.classList.remove('show');
        };
        if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
        if (themeToggleMenu) themeToggleMenu.addEventListener('click', toggleTheme);
        if (openDrawer) openDrawer.addEventListener('click', showDrawer);
        if (closeDrawer) closeDrawer.addEventListener('click', hideDrawer);
        if (drawerBackdrop) drawerBackdrop.addEventListener('click', hideDrawer);
        syncTheme();

        const detailBackdrop = document.getElementById('detailModalBackdrop');
        const detailClose = document.getElementById('detailModalClose');
        const detailTitle = document.getElementById('detailModalTitle');
        const detailKicker = document.getElementById('detailModalKicker');
        const detailBody = document.getElementById('detailModalBody');
        const closeDetail = () => {
          if (!detailBackdrop) return;
          detailBackdrop.classList.remove('show');
          detailBackdrop.setAttribute('aria-hidden', 'true');
          detailBody.innerHTML = '';
        };
        document.addEventListener('click', (event) => {
          const trigger = event.target.closest('[data-detail-modal]');
          if (!trigger || !detailBackdrop) return;
          const source = document.querySelector(trigger.dataset.detailModal);
          if (!source) return;
          detailTitle.textContent = trigger.dataset.detailTitle || source.dataset.detailTitle || 'Details';
          detailKicker.textContent = trigger.dataset.detailKicker || source.dataset.detailKicker || 'Details';
          detailBody.innerHTML = source.innerHTML;
          detailBackdrop.classList.add('show');
          detailBackdrop.setAttribute('aria-hidden', 'false');
        });
        if (detailClose) detailClose.addEventListener('click', closeDetail);
        if (detailBackdrop) detailBackdrop.addEventListener('click', (event) => {
          if (event.target === detailBackdrop) closeDetail();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeDetail();
        });
      })();
    </script>
  </body>
</html>
