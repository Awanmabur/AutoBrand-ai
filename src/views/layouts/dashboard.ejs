<%
  const resolvedAppName = typeof appName !== 'undefined' && appName ? appName : 'AutoBrand AI';
  const resolvedTitle = typeof title !== 'undefined' && title ? `${title} | ${resolvedAppName}` : resolvedAppName;
%>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= resolvedTitle %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dashboard-experience.css?v=20260723-meta-publishing-v3">
  </head>
  <body>
    <%
      const firstName = user && user.name ? user.name.split(' ')[0] : 'User';
      const initials = user && user.name
        ? user.name.split(' ').map((part) => part[0]).join('').slice(0, 2).toUpperCase()
        : 'AB';
      const active = (matches) => matches.some((match) => currentPath === match || currentPath.startsWith(`${match}/`));
      const userRole = user && user.role ? user.role : 'brand_owner';
      const canSeeAdminTools = ['super_admin', 'platform_admin', 'billing_admin', 'ai_manager', 'integration_manager', 'support_agent', 'analyst'].includes(userRole);
      const canSeePlans = ['super_admin', 'billing_admin', 'ai_manager', 'platform_admin'].includes(userRole) || (Array.isArray(user && user.permissions) && user.permissions.some((permission) => ['*', 'plans.view'].includes(permission)));
      const navGroups = [
        {
          label: 'Overview',
          links: [
            { href: '/dashboard/overview', icon: 'home', label: 'Dashboard', badge: 'Home', active: currentPath === '/dashboard' || active(['/dashboard/overview']) },
            { href: '/dashboard/quick-create', icon: 'plus', label: 'Full Composer', badge: 'AI', active: active(['/dashboard/quick-create', '/dashboard/actions/ai']) },
            { href: '/dashboard/brand-brain', icon: 'brain', label: 'Brand Brain', badge: 'Data', active: active(['/dashboard/brand-brain', '/dashboard/actions/brands']) },
            { href: '/dashboard/content-library', icon: 'edit', label: 'Content Library', badge: 'Drafts', active: active(['/dashboard/content-library', '/dashboard/actions/posts']) }
          ]
        },
        {
          label: 'Planning & Creative',
          links: [
            { href: '/dashboard/campaigns', icon: 'grid', label: 'Campaigns & Growth', badge: 'Flow', active: active(['/dashboard/campaigns', '/dashboard/actions/campaigns', '/dashboard/actions/growth-studio']) },
            { href: '/dashboard/media', icon: 'image', label: 'Media & Images', badge: 'Assets', active: active(['/dashboard/media', '/dashboard/actions/media']) },
            { href: '/dashboard/video-system', icon: 'play', label: 'Video Studio', badge: 'Video', active: active(['/dashboard/video-system', '/dashboard/actions/videos', '/dashboard/actions/templates']) },
            { href: '/dashboard/avatar-video', icon: 'avatar', label: 'Avatar Video', badge: 'Pro', active: active(['/dashboard/avatar-video', '/dashboard/actions/avatars']) }
          ]
        },
        {
          label: 'Publishing',
          links: [
            { href: '/dashboard/calendar', icon: 'calendar', label: 'Calendar & Schedule', badge: 'Plan', active: active(['/dashboard/calendar', '/dashboard/actions/calendar']) },
            { href: '/dashboard/social', icon: 'plug', label: 'Social Channels', badge: 'API', active: active(['/dashboard/social', '/dashboard/actions/social']) },
            { href: '/dashboard/approvals', icon: 'check', label: 'Approvals & Handoff', badge: 'Review', active: active(['/dashboard/approvals', '/dashboard/actions/approvals', '/dashboard/actions/posts/handoff']) },
            { href: '/dashboard/analytics', icon: 'chart', label: 'Analytics', badge: 'Live', active: active(['/dashboard/analytics', '/dashboard/actions/analytics']) },
            { href: '/dashboard/notifications', icon: 'message', label: 'Notifications', badge: 'Inbox', active: active(['/dashboard/notifications', '/dashboard/actions/notifications']) }
          ]
        },
        {
          label: 'Admin',
          links: [
            { href: '/dashboard/team', icon: 'users', label: 'Team & Roles', badge: 'RBAC', active: active(['/dashboard/team', '/dashboard/actions/team']) },
            { href: '/dashboard/billing', icon: 'card', label: 'Billing & Usage', badge: 'Plan', active: active(['/dashboard/billing']) },
            ...(canSeePlans ? [{ href: '/dashboard/plans', icon: 'card', label: 'Plan Management', badge: 'Plans', active: active(['/dashboard/plans', '/dashboard/actions/admin/plans']) }] : []),
            { href: '/dashboard/settings', icon: 'settings', label: 'Settings & Security', badge: 'Config', active: active(['/dashboard/settings', '/dashboard/actions/settings']) },
            ...(canSeeAdminTools ? [{ href: '/dashboard/admin', icon: 'shield', label: 'Admin', badge: 'Root', active: active(['/dashboard/admin', '/dashboard/actions/admin']) }] : [])
          ]
        }
      ];
    %>

