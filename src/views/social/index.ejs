<section class="workspace-hero compact-hero channel-hero-clean">
  <div>
    <p class="eyebrow">channels</p>
    <h2>Connect your publishing channels</h2>
    <p>Click a platform, choose the brand, connect the account, and it is ready for posts. Details stay inside each channel preview page so this screen stays clean.</p>
  </div>
  <div class="social-health clean-health">
    <span class="connector-icon connector-google_business">g</span>
    <div><strong><%= accounts.filter((account) => ['connected', 'mock'].includes(account.status)).length %> connected</strong><p>Ready channels across your brands</p></div>
  </div>
</section>

<% if (error) { %><p class="form-error"><%= error %></p><% } %>
<% if (notice) { %><p class="form-success"><%= String(notice).replace(/_/g, ' ') %></p><% } %>

<% if (!brands.length) { %>
  <section class="panel empty-channel-state"><p class="form-error">Create a Brand Brain first.</p><a class="button" href="/brands/create">Create brand</a></section>
<% } else { %>
  <section class="channel-grid-clean" aria-label="Available channels">
    <% const defaultBrand = brands[0] || null; %>
    <% platforms.forEach((platform) => { %>
      <% const platformAccounts = accounts.filter((account) => account.platform === platform.key && ['connected', 'mock'].includes(account.status)); %>
      <% const disconnectedAccounts = accounts.filter((account) => account.platform === platform.key && account.status === 'disconnected'); %>
      <% const firstAccount = platformAccounts[0]; %>
      <% const youtubeDirectHref = platform.key === 'youtube' && youtubeReady && defaultBrand ? `/social/youtube/connect?brand=${defaultBrand._id}` : ''; %>
      <article class="channel-card-clean connector-<%= platform.key %>-tone" data-channel-card="<%= platform.key %>">
        <% if (youtubeDirectHref) { %>
          <a class="channel-icon-button" href="<%= youtubeDirectHref %>" aria-label="Connect <%= platform.name %>">
            <span class="connector-icon connector-<%= platform.key %>"><%= platform.icon || platform.shortName.slice(0, 1) %></span>
          </a>
        <% } else { %>
          <button class="channel-icon-button" type="button" data-open-connector="<%= platform.key %>" aria-label="Connect <%= platform.name %>">
            <span class="connector-icon connector-<%= platform.key %>"><%= platform.icon || platform.shortName.slice(0, 1) %></span>
          </button>
        <% } %>
        <div class="channel-card-body">
          <div>
            <h3><%= platform.name %></h3>
            <p><%= platform.description %></p>
          </div>
          <div class="channel-card-meta">
            <span class="status-pill"><%= platformAccounts.length ? `${platformAccounts.length} connected` : disconnectedAccounts.length ? 'disconnected' : 'not connected' %></span>
            <span><%= platform.kind === 'oauth' ? 'OAuth' : 'API' %></span>
          </div>
        </div>
        <div class="channel-card-actions">
          <% if (youtubeDirectHref) { %>
            <a class="button" href="<%= youtubeDirectHref %>"><%= platformAccounts.length ? 'Reconnect YouTube' : platform.primaryAction %></a>
            <% if (brands.length > 1) { %><button class="button ghost" type="button" data-open-connector="<%= platform.key %>">Choose brand</button><% } %>
          <% } else { %>
            <button class="button" type="button" data-open-connector="<%= platform.key %>"><%= platformAccounts.length ? 'Add another' : platform.primaryAction %></button>
          <% } %>
          <% if (firstAccount) { %><a class="button ghost" href="/social/<%= firstAccount._id %>">Preview</a><% } %>
        </div>
      </article>
    <% }) %>
  </section>

  <section class="panel connected-preview-panel">
    <div class="section-heading-row">
      <div><p class="eyebrow">connected</p><h2>Channel previews</h2><p class="muted">Only the essentials are shown here. Open Preview for IDs, permissions, tokens status, and more actions.</p></div>
    </div>
    <% const activeAccounts = accounts.filter((account) => ['connected', 'mock'].includes(account.status)); %>
    <% const inactiveAccounts = accounts.filter((account) => !['connected', 'mock'].includes(account.status)); %>
    <% if (!accounts.length) { %>
      <article class="empty-state clean-empty"><h2>No channels yet</h2><p>Click one of the platform icons above to connect your first channel.</p></article>
    <% } else { %>
      <div class="connected-card-grid">
        <% activeAccounts.forEach((account) => { %>
          <article class="connected-channel-card">
            <div class="connected-card-main">
              <span class="connector-icon connector-<%= account.platform %>"><%= account.platform === 'linkedin' ? 'in' : account.platform.slice(0, 1) %></span>
              <div>
                <p class="eyebrow"><%= account.brand ? account.brand.name : 'Missing brand' %></p>
                <h3><%= account.accountName %></h3>
                <p class="muted"><%= account.platform.replace('_', ' ') %></p>
              </div>
            </div>
            <div class="connected-card-actions">
              <span class="status-pill"><%= account.status %></span>
              <a class="button ghost" href="/social/<%= account._id %>">Preview</a>
            </div>
          </article>
        <% }) %>
      </div>

      <% if (inactiveAccounts.length) { %>
        <div class="section-heading-row mini-heading-row">
          <div><p class="eyebrow">inactive</p><h3>Disconnected / needs reconnect</h3></div>
        </div>
        <div class="connected-card-grid disconnected-card-grid">
          <% inactiveAccounts.forEach((account) => { %>
            <article class="connected-channel-card is-disconnected">
              <div class="connected-card-main">
                <span class="connector-icon connector-<%= account.platform %>"><%= account.platform === 'linkedin' ? 'in' : account.platform.slice(0, 2) %></span>
                <div>
                  <p class="eyebrow"><%= account.brand ? account.brand.name : 'Missing brand' %></p>
                  <h3><%= account.accountName %></h3>
                  <p class="muted"><%= account.platform.replace('_', ' ') %></p>
                </div>
              </div>
              <div class="connected-card-actions">
                <span class="status-pill muted-pill"><%= account.status %></span>
                <a class="button ghost" href="/social/<%= account._id %>">Preview</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    <% } %>
  </section>

  <div class="channel-modal-backdrop" data-channel-modal hidden>
    <section class="channel-modal-card" role="dialog" aria-modal="true" aria-label="Connect channel">
      <button class="modal-close" type="button" data-close-connector aria-label="Close">×</button>
      <% platforms.forEach((platform) => { %>
        <div class="channel-connect-pane" data-connector-pane="<%= platform.key %>" hidden>
          <div class="channel-modal-head">
            <span class="connector-icon connector-<%= platform.key %>"><%= platform.icon || platform.shortName.slice(0, 1) %></span>
            <div>
              <p class="eyebrow">connect</p>
              <h2><%= platform.name %></h2>
              <p class="muted"><%= platform.hint %></p>
            </div>
          </div>

          <% if (platform.key === 'facebook') { %>
            <div class="brand-connect-list modal-brand-list">
              <% brands.forEach((brand) => { %>
                <% const brandAccounts = accounts.filter((account) => account.platform === 'facebook' && account.brand && account.brand._id.toString() === brand._id.toString() && ['connected', 'mock'].includes(account.status)); %>
                <div class="brand-connect-row clean-connect-row">
                  <span><strong><%= brand.name %></strong><small><%= brandAccounts.length ? `${brandAccounts.length} Page(s) connected` : 'No Facebook Page connected yet' %></small></span>
                  <% if (facebookReady && !facebookSetup.canStartOAuth) { %>
                    <button class="button ghost" type="button" disabled>Setup needed</button>
                  <% } else { %>
                    <a class="button" href="/social/facebook/connect?brand=<%= brand._id %>"><%= brandAccounts.length ? 'Reconnect / add Pages' : 'Open Facebook' %></a>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <% if (facebookSetupRequired || (facebookReady && !facebookSetup.canStartOAuth)) { %>
              <div class="setup-callout compact-setup-callout">
                <strong>Facebook setup check</strong>
                <% facebookSetup.issues.forEach((issue) => { %><p class="form-error"><%= issue %></p><% }) %>
              </div>
            <% } %>
          <% } else if (platform.key === 'youtube') { %>
            <div class="brand-connect-list modal-brand-list">
              <% brands.forEach((brand) => { %>
                <% const brandAccounts = accounts.filter((account) => account.platform === 'youtube' && account.brand && account.brand._id.toString() === brand._id.toString() && ['connected', 'mock'].includes(account.status)); %>
                <div class="brand-connect-row clean-connect-row">
                  <span><strong><%= brand.name %></strong><small><%= brandAccounts.length ? `${brandAccounts.length} YouTube channel(s) connected` : 'No YouTube channel connected yet' %></small></span>
                  <% if (!youtubeReady) { %>
                    <button class="button ghost" type="button" disabled>Setup needed</button>
                  <% } else { %>
                    <a class="button" href="/social/youtube/connect?brand=<%= brand._id %>"><%= brandAccounts.length ? 'Reconnect YouTube' : 'Open YouTube' %></a>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <% if (youtubeSetupRequired || !youtubeReady) { %>
              <div class="setup-callout compact-setup-callout">
                <strong>YouTube setup check</strong>
                <p class="muted">Add YOUTUBE_CLIENT_ID, YOUTUBE_CLIENT_SECRET, and YOUTUBE_CALLBACK_URL in .env, then add the callback URL in Google Cloud Console.</p>
              </div>
            <% } %>
          <% } else if (platform.key === 'linkedin') { %>
            <div class="brand-connect-list modal-brand-list">
              <% brands.forEach((brand) => { %>
                <% const brandAccounts = accounts.filter((account) => account.platform === 'linkedin' && account.brand && account.brand._id.toString() === brand._id.toString() && ['connected', 'mock'].includes(account.status)); %>
                <div class="brand-connect-row clean-connect-row">
                  <span><strong><%= brand.name %></strong><small><%= brandAccounts.length ? `${brandAccounts.length} LinkedIn profile/Page(s) connected` : 'No LinkedIn profile or Page connected yet' %></small></span>
                  <% if (!linkedinReady) { %>
                    <button class="button ghost" type="button" disabled>Setup needed</button>
                  <% } else { %>
                    <a class="button" href="/social/linkedin/connect?brand=<%= brand._id %>"><%= brandAccounts.length ? 'Reconnect LinkedIn' : 'Open LinkedIn' %></a>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <% if (linkedinSetupRequired || !linkedinReady) { %>
              <div class="setup-callout compact-setup-callout">
                <strong>LinkedIn setup check</strong>
                <p class="muted">Add LINKEDIN_CLIENT_ID, LINKEDIN_CLIENT_SECRET, and LINKEDIN_CALLBACK_URL in .env, then add the callback URL in LinkedIn Developer Portal.</p>
              </div>
            <% } %>
          <% } else if (platform.key === 'tiktok') { %>
            <div class="brand-connect-list modal-brand-list">
              <% brands.forEach((brand) => { %>
                <% const brandAccounts = accounts.filter((account) => account.platform === 'tiktok' && account.brand && account.brand._id.toString() === brand._id.toString() && ['connected', 'mock'].includes(account.status)); %>
                <div class="brand-connect-row clean-connect-row">
                  <span><strong><%= brand.name %></strong><small><%= brandAccounts.length ? `${brandAccounts.length} TikTok account(s) connected` : 'No TikTok account connected yet' %></small></span>
                  <% if (!tiktokReady) { %>
                    <button class="button ghost" type="button" disabled>Setup needed</button>
                  <% } else { %>
                    <a class="button" href="/social/tiktok/connect?brand=<%= brand._id %>"><%= brandAccounts.length ? 'Reconnect TikTok' : 'Open TikTok' %></a>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <% if (tiktokSetupRequired || !tiktokReady) { %>
              <div class="setup-callout compact-setup-callout">
                <strong>TikTok setup check</strong>
                <p class="muted">Add TIKTOK_CLIENT_KEY, TIKTOK_CLIENT_SECRET, and TIKTOK_CALLBACK_URL in .env, then add this callback URL in TikTok Developer Portal.</p>
              </div>
            <% } %>
          <% } else if (['google_business', 'pinterest', 'x', 'threads'].includes(platform.key)) { %>
            <% const oauthReady = platform.key === 'google_business' ? googleBusinessReady : platform.key === 'pinterest' ? pinterestReady : platform.key === 'x' ? xReady : threadsReady; %>
            <% const setupRequired = platform.key === 'google_business' ? googleBusinessSetupRequired : platform.key === 'pinterest' ? pinterestSetupRequired : platform.key === 'x' ? xSetupRequired : threadsSetupRequired; %>
            <% const connectorPath = platform.key === 'google_business' ? 'google-business' : platform.key; %>
            <div class="brand-connect-list modal-brand-list">
              <% brands.forEach((brand) => { %>
                <% const brandAccounts = accounts.filter((account) => account.platform === platform.key && account.brand && account.brand._id.toString() === brand._id.toString() && ['connected', 'mock'].includes(account.status)); %>
                <div class="brand-connect-row clean-connect-row">
                  <span><strong><%= brand.name %></strong><small><%= brandAccounts.length ? `${brandAccounts.length} ${platform.shortName} account(s) connected` : `No ${platform.shortName} account connected yet` %></small></span>
                  <% if (!oauthReady) { %>
                    <button class="button ghost" type="button" disabled>Setup needed</button>
                  <% } else { %>
                    <a class="button" href="/social/<%= connectorPath %>/connect?brand=<%= brand._id %>"><%= brandAccounts.length ? `Reconnect ${platform.shortName}` : platform.primaryAction %></a>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <% if (setupRequired || !oauthReady) { %>
              <div class="setup-callout compact-setup-callout">
                <strong><%= platform.shortName %> setup check</strong>
                <p class="muted"><%= platform.setupHint || `Add ${platform.shortName} API credentials to .env before connecting.` %></p>
              </div>
            <% } %>
          <% } else { %>
            <form action="/social/api-connect" method="post" class="form-grid compact-channel-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="platform" value="<%= platform.key %>">
              <label class="span-2">Brand
                <select name="brand" required><% brands.forEach((brand) => { %><option value="<%= brand._id %>"><%= brand.name %></option><% }) %></select>
              </label>
              <label>Account name
                <input name="accountName" required placeholder="<%= platform.shortName %> name">
              </label>
              <label>Account ID
                <input name="accountId" required placeholder="Profile, page, organization, or board ID">
              </label>
              <label class="span-2">Access token
                <input name="accessToken" type="password" autocomplete="off" required placeholder="Paste provider access token">
              </label>
              <label class="span-2 optional-field">Refresh token
                <input name="refreshToken" type="password" autocomplete="off" placeholder="Optional">
              </label>
              <input type="hidden" name="permissions" value="publish,analytics_read">
              <button class="button span-2" type="submit">Connect <%= platform.shortName %></button>
            </form>
          <% } %>
        </div>
      <% }) %>
    </section>
  </div>
<% } %>

<script>
  (function () {
    const modal = document.querySelector('[data-channel-modal]');
    const panes = Array.from(document.querySelectorAll('[data-connector-pane]'));
    const openers = Array.from(document.querySelectorAll('[data-open-connector]'));
    const close = document.querySelector('[data-close-connector]');
    function openPane(key) {
      if (!modal) return;
      panes.forEach((pane) => { pane.hidden = pane.dataset.connectorPane !== key; });
      modal.hidden = false;
      document.body.classList.add('modal-open');
    }
    function closePane() {
      if (!modal) return;
      modal.hidden = true;
      document.body.classList.remove('modal-open');
    }
    openers.forEach((button) => button.addEventListener('click', () => openPane(button.dataset.openConnector)));
    close?.addEventListener('click', closePane);
    modal?.addEventListener('click', (event) => { if (event.target === modal) closePane(); });
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closePane(); });
  })();
</script>
