<section class="workspace-hero compact-hero channel-preview-hero">
  <div>
    <p class="eyebrow">channel preview</p>
    <h2><%= account.accountName %></h2>
    <p><%= platform.description %></p>
  </div>
  <div class="social-health clean-health">
    <span class="connector-icon connector-<%= account.platform %>"><%= platform.icon || account.platform.slice(0, 1) %></span>
    <div><strong><%= account.status %></strong><p><%= account.platform.replace('_', ' ') %></p></div>
  </div>

</section>

<% if (notice) { %><p class="form-success"><%= notice %></p><% } %>

<section class="preview-detail-grid">
  <article class="panel channel-detail-card">
    <div class="section-heading-row">
      <div><p class="eyebrow">overview</p><h2>Account details</h2></div>
      <a class="button ghost" href="/social">Back to channels</a>
    </div>
    <dl class="clean-detail-list">
      <div><dt>Brand</dt><dd><%= account.brand ? account.brand.name : 'Missing brand' %></dd></div>
      <div><dt>Platform</dt><dd><%= platform.name %></dd></div>
      <div><dt>Account ID</dt><dd><%= account.accountId || 'Not provided' %></dd></div>
      <div><dt>Status</dt><dd><span class="status-pill"><%= account.status %></span></dd></div>
      <div><dt>Last sync</dt><dd><%= account.lastSyncAt ? account.lastSyncAt.toLocaleString() : 'Not synced yet' %></dd></div>
      <div><dt>Created</dt><dd><%= account.createdAt ? account.createdAt.toLocaleString() : 'Unknown' %></dd></div>
    </dl>
  </article>

  <article class="panel channel-detail-card">
    <div class="section-heading-row"><div><p class="eyebrow">publishing</p><h2>Actions</h2></div></div>
    <div class="channel-preview-actions">
      <a class="button" href="/posts/new?brand=<%= account.brand ? account.brand._id : '' %>">Create post</a>
      <form action="/social/<%= account._id %>/reconnect" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="button ghost" type="submit">Reconnect</button>
      </form>
      <% if (account.platform === 'tiktok') { %>
        <form action="/social/<%= account._id %>/tiktok-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync TikTok info</button>
        </form>
      <% } %>
      <% if (account.platform === 'youtube') { %>
        <form action="/social/<%= account._id %>/youtube-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync YouTube channel</button>
        </form>
      <% } %>
      <% if (account.platform === 'linkedin') { %>
        <form action="/social/<%= account._id %>/linkedin-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync LinkedIn info</button>
        </form>
      <% } %>
      <% if (account.platform === 'google_business') { %>
        <form action="/social/<%= account._id %>/google-business-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync Google Profile</button>
        </form>
      <% } %>
      <% if (account.platform === 'pinterest') { %>
        <form action="/social/<%= account._id %>/pinterest-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync Pinterest board</button>
        </form>
      <% } %>
      <% if (account.platform === 'x') { %>
        <form action="/social/<%= account._id %>/x-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync X profile</button>
        </form>
      <% } %>
      <% if (account.platform === 'threads') { %>
        <form action="/social/<%= account._id %>/threads-sync" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button ghost" type="submit">Sync Threads profile</button>
        </form>
      <% } %>
      <form action="/social/<%= account._id %>/disconnect" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="button ghost danger-soft" type="submit">Disconnect</button>
      </form>
    </div>
    <div class="channel-capability-card">
      <h3>Available permissions</h3>
      <% if (account.permissions && account.permissions.length) { %>
        <div class="permission-pills"><% account.permissions.forEach((permission) => { %><span><%= permission %></span><% }) %></div>
      <% } else { %>
        <p class="muted">No permissions were saved for this account.</p>
      <% } %>
    </div>
  </article>
  <article class="panel channel-detail-card channel-edit-card">
    <div class="section-heading-row"><div><p class="eyebrow">edit</p><h2>Update connection</h2><p class="muted">Change the saved label, provider ID, permissions, or paste a fresh token. Changes reflect immediately after save.</p></div></div>
    <form action="/social/<%= account._id %>/update" method="post" class="form-grid compact-channel-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="span-2">Account name
        <input name="accountName" value="<%= account.accountName %>" required>
      </label>
      <label class="span-2">Account ID
        <input name="accountId" value="<%= account.accountId || '' %>">
      </label>
      <label>Status
        <select name="status">
          <% ['connected', 'mock', 'needs_reconnect', 'expired', 'failed', 'disconnected'].forEach((status) => { %>
            <option value="<%= status %>" <%= account.status === status ? 'selected' : '' %>><%= status.replace('_', ' ') %></option>
          <% }) %>
        </select>
      </label>
      <label>Permissions
        <input name="permissions" value="<%= (account.permissions || []).join(', ') %>" placeholder="publish, analytics_read">
      </label>
      <label class="span-2">New access token
        <input type="password" name="accessToken" autocomplete="off" placeholder="Leave blank to keep current token">
      </label>
      <label class="span-2">New refresh token
        <input type="password" name="refreshToken" autocomplete="off" placeholder="Optional">
      </label>
      <button class="button span-2" type="submit">Save connection</button>
    </form>
  </article>

</section>
