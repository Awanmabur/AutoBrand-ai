<section class="panel">
  <p class="eyebrow">Brand Brain</p>
  <% if (brand.logo) { %><img class="brand-logo-preview" src="<%= brand.logo %>" alt="<%= brand.name %> logo"><% } %>
  <h2><%= brand.name %></h2>
  <p><%= brand.description || 'No description yet.' %></p>
  <div class="detail-list">
    <span>Type: <strong><%= brand.businessType || 'Not set' %></strong></span>
    <span>Location: <strong><%= brand.location || 'Not set' %></strong></span>
    <span>Language: <strong><%= brand.language || 'Not set' %></strong></span>
    <span>Audience: <strong><%= brand.targetAudience || 'Not set' %></strong></span>
    <span>Tone: <strong><%= brand.tone || 'Not set' %></strong></span>
    <span>CTA: <strong><%= brand.preferredCta || 'Not set' %></strong></span>
    <span>Frequency: <strong><%= brand.postingFrequency || 'Not set' %></strong></span>
  </div>
  <div class="detail-list">
    <span>Goals: <strong><%= brand.goals.length ? brand.goals.join(', ') : 'Not set' %></strong></span>
    <span>Hashtags: <strong><%= brand.preferredHashtags.length ? brand.preferredHashtags.join(', ') : 'Not set' %></strong></span>
    <span>Blocked words: <strong><%= brand.blockedWords.length ? brand.blockedWords.join(', ') : 'None' %></strong></span>
  </div>
  <div class="detail-list">
    <span>Products: <strong><%= brand.products.length %></strong></span>
    <span>Offers: <strong><%= brand.offers.length %></strong></span>
    <span>Social links: <strong><%= brand.socialLinks.length %></strong></span>
    <span>Brand rules: <strong><%= brand.brandRules.length %></strong></span>
  </div>
  <div class="nav-actions">
    <a class="button" href="/videos">Generate AI video plan</a>
    <a class="button ghost" href="/brands/<%= brand._id %>/edit">Edit Brand Brain</a>
  </div>
</section>
