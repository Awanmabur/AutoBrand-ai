<% const value = (name, fallback = '') => typeof brand !== 'undefined' && brand[name] ? brand[name] : fallback; %>
<% const listValue = (name) => Array.isArray(value(name)) ? value(name).join('\n') : value(name); %>
<% const objectList = (name, fields) => Array.isArray(value(name)) ? value(name).map((item) => fields.map((field) => item[field] || '').join(' | ')).join('\n') : value(name); %>
<div class="form-grid brand-brain-form" data-brand-upload-form data-brand-id="<%= typeof brand !== 'undefined' && brand && brand._id ? brand._id : '' %>">
  <label>Brand name <input name="name" value="<%= value('name') %>" required></label>
  <input id="brand-logo-url" name="logo" type="hidden" value="<%= value('logo') %>" data-brand-upload-url="logo">
  <input id="brand-logo-public-id" name="logoPublicId" type="hidden" value="<%= value('logoPublicId') %>" data-brand-upload-public-id="logo">
  <input name="favicon" type="hidden" value="<%= value('favicon') %>" data-brand-upload-url="favicon">
  <input name="faviconPublicId" type="hidden" value="<%= value('faviconPublicId') %>" data-brand-upload-public-id="favicon">
  <input name="coverImage" type="hidden" value="<%= value('coverImage') %>" data-brand-upload-url="cover">
  <input name="coverImagePublicId" type="hidden" value="<%= value('coverImagePublicId') %>" data-brand-upload-public-id="cover">
  <input name="assetUploadsJson" type="hidden" value="[]" data-brand-upload-assets>
  <label class="brand-upload-control">Upload logo<input id="brand-logo-file" type="file" accept="image/*" data-brand-upload-file="logo"><small data-brand-upload-status="logo">Upload a logo from your device.</small><img data-brand-upload-preview="logo" src="<%= value('logo') %>" alt="Logo preview" <%= value('logo') ? '' : 'hidden' %>></label>
  <label class="brand-upload-control">Upload favicon<input type="file" accept="image/*" data-brand-upload-file="favicon"><small data-brand-upload-status="favicon">Upload a square icon.</small><img data-brand-upload-preview="favicon" src="<%= value('favicon') %>" alt="Favicon preview" <%= value('favicon') ? '' : 'hidden' %>></label>
  <label class="brand-upload-control">Upload cover image<input type="file" accept="image/*" data-brand-upload-file="cover"><small data-brand-upload-status="cover">Upload a wide cover image.</small><img data-brand-upload-preview="cover" src="<%= value('coverImage') %>" alt="Cover preview" <%= value('coverImage') ? '' : 'hidden' %>></label>
  <label class="brand-upload-control span-2">Upload extra brand assets<input type="file" multiple accept="image/*,video/*,.pdf" data-brand-upload-file="asset"><small data-brand-upload-status="asset">Upload product photos, PDFs, guidelines, and sample videos.</small></label>
  <label>Industry <input name="industry" value="<%= value('industry') %>"></label>
  <label>Business type <input name="businessType" value="<%= value('businessType') %>"></label>
  <label>Website <input name="website" value="<%= value('website') %>"></label>
  <label>Location <input name="location" value="<%= value('location') %>"></label>
  <label>Timezone <input name="timezone" value="<%= value('timezone', 'Africa/Kampala') %>"></label>
  <label>Language <input name="language" value="<%= value('language', 'English') %>"></label>
  <label>Target countries <input name="targetCountries" value="<%= listValue('targetCountries') %>" placeholder="Uganda, Kenya, USA"></label>
  <label>Target audience <input name="targetAudience" value="<%= value('targetAudience') %>"></label>
  <label>Audience age range <input name="audienceAgeRange" value="<%= value('audienceAgeRange') %>"></label>
  <label>Tone <input name="tone" value="<%= value('tone', 'clean, friendly, local') %>"></label>
  <label>Tone of voice <input name="toneOfVoice" value="<%= value('toneOfVoice') %>"></label>
  <label>Writing style <input name="writingStyle" value="<%= value('writingStyle') %>"></label>
  <label>Preferred CTA <input name="preferredCta" value="<%= value('preferredCta') %>"></label>
  <label>Posting frequency <input name="postingFrequency" value="<%= value('postingFrequency') %>" placeholder="2 posts per day"></label>
  <label>Local style <input name="localStyle" value="<%= value('localStyle') %>"></label>
  <label>Font style <input name="fontStyle" value="<%= value('fontStyle') %>"></label>
  <label>Fonts <input name="fonts" value="<%= listValue('fonts') %>" placeholder="Inter, Poppins"></label>
  <label>Slogan <input name="slogan" value="<%= value('slogan') %>"></label>
  <label>Tagline <input name="tagline" value="<%= value('tagline') %>"></label>
  <label>USP <input name="uniqueSellingPoint" value="<%= value('uniqueSellingPoint') %>"></label>
  <label class="span-2">Description <textarea name="description" rows="5"><%= value('description') %></textarea></label>
  <label class="span-2">Brand story <textarea name="brandStory" rows="4"><%= value('brandStory') %></textarea></label>
  <label>Mission <textarea name="mission" rows="3"><%= value('mission') %></textarea></label>
  <label>Vision <textarea name="vision" rows="3"><%= value('vision') %></textarea></label>
  <label class="span-2">Values <textarea name="values" rows="3"><%= listValue('values') %></textarea></label>
  <label class="span-2">Products <textarea name="products" rows="4" placeholder="Name | Price | Description"><%= objectList('products', ['name', 'price', 'description']) %></textarea></label>
  <label class="span-2">Services <textarea name="services" rows="4" placeholder="Name | Price | Description"><%= objectList('services', ['name', 'price', 'description']) %></textarea></label>
  <label class="span-2">Offers <textarea name="offers" rows="4" placeholder="Title | Description"><%= objectList('offers', ['title', 'description']) %></textarea></label>
  <label>Pricing notes <textarea name="pricingNotes" rows="3"><%= value('pricingNotes') %></textarea></label>
  <label>Guarantees <textarea name="guarantees" rows="3"><%= listValue('guarantees') %></textarea></label>
  <label class="span-2">FAQs <textarea name="faqs" rows="3" placeholder="Question | Answer"><%= objectList('faqs', ['question', 'answer']) %></textarea></label>
  <label class="span-2">Social links <textarea name="socialLinks" rows="3" placeholder="facebook | https://facebook.com/page"><%= objectList('socialLinks', ['platform', 'url']) %></textarea></label>
  <label class="span-2">Goals <textarea name="goals" rows="3"><%= listValue('goals') %></textarea></label>
  <label>Customer pain points <textarea name="customerPainPoints" rows="3"><%= listValue('customerPainPoints') %></textarea></label>
  <label>Customer desires <textarea name="customerDesires" rows="3"><%= listValue('customerDesires') %></textarea></label>
  <label>Common objections <textarea name="commonObjections" rows="3"><%= listValue('customerObjections') || listValue('commonObjections') %></textarea></label>
  <label>Audience interests <textarea name="audienceInterests" rows="3"><%= listValue('audienceInterests') %></textarea></label>
  <label class="span-2">Customer personas <textarea name="customerPersonas" rows="3" placeholder="Name | Description | Goals | Objections"><%= objectList('customerPersonas', ['name', 'description', 'goals', 'objections']) %></textarea></label>
  <label class="span-2">Testimonials <textarea name="testimonials" rows="3" placeholder="Author | Quote"><%= objectList('testimonials', ['author', 'quote']) %></textarea></label>
  <label class="span-2">Brand rules <textarea name="brandRules" rows="3"><%= listValue('brandRules') %></textarea></label>
  <label>Content pillars <textarea name="contentPillars" rows="3"><%= listValue('contentPillars') %></textarea></label>
  <label>Content dos <textarea name="contentDos" rows="3"><%= listValue('contentDos') %></textarea></label>
  <label>Content don'ts <textarea name="contentDonts" rows="3"><%= listValue('contentDonts') %></textarea></label>
  <label>Compliance notes <textarea name="complianceNotes" rows="3"><%= listValue('complianceNotes') %></textarea></label>
  <label>Preferred hashtags <textarea name="preferredHashtags" rows="3"><%= listValue('preferredHashtags') %></textarea></label>
  <label>Banned words <textarea name="bannedWords" rows="3"><%= listValue('bannedWords') %></textarea></label>
  <label>Blocked words <textarea name="blockedWords" rows="3"><%= listValue('blockedWords') %></textarea></label>
  <label>Preferred words <textarea name="preferredWords" rows="3"><%= listValue('preferredWords') %></textarea></label>
  <label>Competitors <textarea name="competitors" rows="3"><%= listValue('competitors') %></textarea></label>
  <label class="span-2">Competitor links <textarea name="competitorLinks" rows="3" placeholder="Name | URL | Notes"><%= objectList('competitorLinks', ['name', 'url', 'notes']) %></textarea></label>
  <label class="span-2">Differentiation notes <textarea name="differentiationNotes" rows="3"><%= value('differentiationNotes') %></textarea></label>
  <label>Brand colors <textarea name="brandColors" rows="3"><%= listValue('brandColors') %></textarea></label>
  <label>Emoji usage <input name="emojiUsage" value="<%= value('emojiUsage') %>"></label>
  <label>Hashtag style <input name="hashtagStyle" value="<%= value('hashtagStyle') %>"></label>
  <label>Formality level <input name="formalityLevel" value="<%= value('formalityLevel') %>"></label>
  <label>Humor level <input name="humorLevel" value="<%= value('humorLevel') %>"></label>
  <label>Default posting times <textarea name="defaultPostingTimes" rows="3"><%= listValue('defaultPostingTimes') %></textarea></label>
  <label class="checkbox-row"><input name="approvalRequiredByDefault" type="checkbox" <%= value('approvalRequiredByDefault') ? 'checked' : '' %>> Approval required by default</label>
  <label class="span-2">Saved prompts <textarea name="savedPrompts" rows="3" placeholder="Title | Task type | Prompt"><%= objectList('savedPrompts', ['title', 'taskType', 'prompt']) %></textarea></label>
  <label>Rejected styles <textarea name="rejectedStyles" rows="3"><%= listValue('rejectedStyles') %></textarea></label>
  <label>High-performing topics <textarea name="highPerformingTopics" rows="3"><%= listValue('highPerformingTopics') %></textarea></label>
  <label class="span-2">Brand knowledge base <textarea name="brandKnowledgeBase" rows="4" placeholder="Title | Source | Content"><%= objectList('brandKnowledgeBase', ['title', 'source', 'content']) %></textarea></label>
  <fieldset class="span-2 fieldset">
    <legend>Auto posting brain</legend>
    <label class="checkbox-row span-2"><input name="autoPostingEnabled" type="checkbox" <%= value('autoPosting') && value('autoPosting').enabled ? 'checked' : '' %>> Enable automatic posting for this brand</label>
    <label>Default frequency
      <select name="autoFrequencyUnit">
        <% const auto = value('autoPosting') || {}; %>
        <option value="day" <%= auto.frequencyUnit === 'day' ? 'selected' : '' %>>Day</option>
        <option value="week" <%= !auto.frequencyUnit || auto.frequencyUnit === 'week' ? 'selected' : '' %>>Week</option>
        <option value="month" <%= auto.frequencyUnit === 'month' ? 'selected' : '' %>>Month</option>
      </select>
    </label>
    <label>Posts/day <input type="number" name="autoPostsPerDay" min="1" max="12" value="<%= auto.postsPerDay || 1 %>"></label>
    <label>Posts/week <input type="number" name="autoPostsPerWeek" min="1" max="60" value="<%= auto.postsPerWeek || 7 %>"></label>
    <label>Posts/month <input type="number" name="autoPostsPerMonth" min="1" max="90" value="<%= auto.postsPerMonth || 30 %>"></label>
    <label>Min images <input type="number" name="imagesPerPostMin" min="1" max="5" value="<%= auto.imagesPerPostMin || 1 %>"></label>
    <label>Max images/slides <input type="number" name="imagesPerPostMax" min="1" max="5" value="<%= auto.imagesPerPostMax || 3 %>"></label>
    <label>Strength target <input type="number" name="strengthTarget" min="80" max="100" value="<%= auto.strengthTarget || 90 %>"></label>
    <label class="span-2">Preferred slots <input name="autoPreferredSlots" value="<%= Array.isArray(auto.preferredSlots) ? auto.preferredSlots.join(', ') : 'morning, evening' %>" placeholder="morning, lunch, evening"></label>
    <label class="span-2">Media mix <input name="autoMediaMix" value="<%= Array.isArray(auto.mediaMix) && auto.mediaMix.length ? auto.mediaMix.join(', ') : 'auto, image, slides, video' %>" placeholder="auto, image, slides, video"></label>
    <label class="span-2">Platform languages <textarea name="platformLanguages" rows="3" placeholder="facebook | English\ninstagram | English"><%= auto.platformLanguages ? Object.entries(auto.platformLanguages).map(([k,v]) => `${k} | ${v}`).join('\n') : '' %></textarea></label>
    <label class="span-2">Customer acquisition goal <textarea name="autoCustomerGoal" rows="3"><%= auto.customerGoal || 'get customers immediately with clear offers, proof, and a direct call to action' %></textarea></label>
    <label class="checkbox-row span-2"><input name="autoRequireMedia" type="checkbox" <%= auto.requireMedia !== false ? 'checked' : '' %>> Require media in automatic posts whenever possible</label>
  </fieldset>

</div>
