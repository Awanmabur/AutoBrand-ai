<section class="panel">
  <h2>Edit Brand Brain</h2>
  <% if (error) { %><p class="form-error"><%= error %></p><% } %>
  <form action="/brands/<%= brand._id %>?_method=PUT" method="post" class="form-stack">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <%- include('_form', { brand }) %>
    <div class="nav-actions">
      <button class="button" type="submit">Update brand</button>
      <a class="button ghost" href="/brands/<%= brand._id %>">Cancel</a>
    </div>
  </form>
</section>
<script src="/js/brand-logo-upload.js?v=20260524-upload-intent"></script>
