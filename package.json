{
  "name": "autobrand-ai-social-saas",
  "version": "1.0.1",
  "private": true,
  "description": "AI social media management SaaS platform",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "worker": "node workers/postWorker.js",
    "seed": "node scripts/seed.js",
    "seed:plans": "node scripts/seedPlans.js",
    "seed:superadmin": "node scripts/seedSuperadmin.js",
    "seed:permissions": "node scripts/seedPermissions.js",
    "seed:platform-rules": "node scripts/seedPlatformRules.js",
    "seed:ai-providers": "node scripts/seedAiProviders.js",
    "lint": "node scripts/checkSyntax.js",
    "test": "node --test test/*.test.js",
    "worker:ai": "node workers/aiGenerationWorker.js",
    "security:static": "node scripts/securityCheck.js",
    "security": "node scripts/securityCheck.js && npm audit --omit=dev",
    "verify": "npm run lint && npm test && npm run security",
    "diagnose:publishing": "node scripts/diagnosePublishing.js",
    "repair:publishing": "node scripts/repairPublishing.js",
    "diagnose:connectivity": "node scripts/diagnoseConnectivity.js"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cloudinary": "^2.0.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.0",
    "ejs": "^3.1.10",
    "express": "^4.18.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.0.0",
    "ffmpeg-static": "^5.2.0",
    "helmet": "^7.0.0",
    "https-proxy-agent": "^7.0.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.48.0",
    "sharp": "^0.33.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
